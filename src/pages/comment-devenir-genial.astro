---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Description from '../components/Description.astro';
import VideoTeaser from '../components/VideoTeaser.astro';
import SpectaclePhotos from '../components/SpectaclePhotos.astro';
import ForYou from '../components/ForYou.astro';
import About from '../components/About.astro';
import Steps from '../components/Steps.astro';
import SocialProof from '../components/SocialProof.astro';
import Faq from '../components/Faq.astro';
import CTA from '../components/CTA.astro';

const description = `
<p>Comment devenir génial ? C'est la question que tout le monde se pose, non ? Et si la réponse était plus simple qu'on ne le croit ?</p>

<p>Dans ce spectacle hybride — entre conte, conférence et méditation guidée — Mathieu raconte comment il a découvert que le génie n'est pas un don, mais une posture. <em>En traitant les autres comme des personnes formidables, ils le deviennent. En se traiter soi-même avec exigence bienveillante, on le devient aussi.</em></p>

<p>À travers des histoires vraies, de l'hypnose et des moments où quelque chose clique, vous découvrirez que la réponse était là depuis le début. Vous êtes déjà génial. Il suffit de le voir.</p>
`;

const forYouItems = [
  "Vous vous posez des questions sur votre place dans le monde",
  "Vous aimez les spectacles qui font réfléchir, pas juste divertir",
  "Vous êtes curieux de découvrir ce que l'hypnose peut révéler",
  "Vous cherchez quelque chose de différent : ni conférence, ni spectacle classique",
  "Vous voulez repartir avec quelque chose qui reste",
];

const steps = [
  {
    number: "1",
    title: "Le Poison",
    description: "Le monde va mal. J'avais perdu confiance. Trois peurs : ne pas être assez, le rejet, l'inconnu. Si ça vous parle, vous êtes au bon endroit."
  },
  {
    number: "2",
    title: "J'ai osé être vulnérable",
    description: "L'histoire de Gaël, en CM2. Le dur de la cour qui m'insultait tous les jours. Jusqu'à ce que je fasse l'inverse de ce que tout le monde attend : lui dire la vérité. Et ce qui s'est passé ensuite..."
  },
  {
    number: "3",
    title: "J'ai osé aimer",
    description: "L'histoire du meilleur râteau du monde. Trois ans à ne rien dire, par peur de perdre. Jusqu'à ce que je comprenne que le rejet ne tue pas. Ce qui tue, c'est le regret de ne pas avoir osé."
  },
  {
    number: "4",
    title: "J'ai osé lâcher prise",
    description: "L'histoire d'un avion raté, une piscine norvégienne, et une rencontre qui n'aurait pas dû arriver. L'imprévu n'est pas un problème — c'est une opportunité déguisée."
  },
  {
    number: "5",
    title: "L'Antidote",
    description: "La réponse à la question. Elle n'est pas ce que vous croyez. Et à la fin, quelque chose clique — par l'hypnose, et les histoires qu'on vient de vivre ensemble."
  },
];

const faqs = [
  {
    question: "C'est quoi ce spectacle exactement ?",
    answer: "Un mélange de conte, de conférence et de méditation guidée. Mathieu raconte des histoires vraies — un gamin qui l'insultait, un râteau magnifique, une rencontre norvégienne — ponctuées de moments d'hypnose et de magie. À la fin, quelque chose clique."
  },
  {
    question: "Est-ce que c'est du développement personnel ?",
    answer: "C'est un spectacle, pas une formation. Le message est là — vous êtes déjà génial, il suffit de le voir — mais il est montré, pas enseigné. À travers des histoires, de l'hypnose et des moments de magie. Pas de discours motivant."
  },
  {
    question: "Est-ce que je dois participer ?",
    answer: "Le spectacle est conçu pour que tout le monde vive l'expérience depuis sa place. L'hypnose est immersive — vous pouvez participer ou simplement vous laisser porter. Et quelques volontaires seront invités sur scène pour un moment d'hypnose."
  },
  {
    question: "Est-ce que l'hypnose fonctionne sur moi ?",
    answer: "Oui, très certainement. Tout le monde est hypnotisable. Chacun réagit différemment, et il existe une petite proportion de personnes très réactives — c'est celles qu'on invite sur scène. Mais l'hypnose immersive fonctionne pour tout le monde, depuis sa chaise."
  },
  {
    question: "À partir de quel âge ?",
    answer: "Ouvert dès 14 ans. Le spectacle parle aux jeunes qui cherchent leur place, aux adultes en quête de sens, à tous ceux qui veulent passer un bon moment et repartir avec quelque chose."
  },
];

const photos = [
  { src: "", alt: "Mathieu en spectacle — moment d'hypnose" },
  { src: "", alt: "Public sous hypnose — moment de connexion" },
];
---

<Layout
  title="Comment devenir génial — Spectacle d'hypnose, magie et sincérité à Grenoble"
  description="Comment devenir génial ? La réponse n'est pas ce que vous croyez. Un spectacle entre conte, conférence et méditation guidée. Grenoble."
>
  <Hero
    title="Comment devenir génial ?"
    tagline="La réponse n'est pas ce que vous croyez. Et je vais vous la montrer — pas vous l'enseigner."
    theme="comment-devenir-genial"
  />

  <Description content={description} />

  <VideoTeaser />

  <ForYou items={forYouItems} title="Ce spectacle est pour vous si..." />

  <SpectaclePhotos photos={photos} />

  <About />

  <Steps steps={steps} />

  <SocialProof />

  <Faq faqs={faqs} />

  <CTA theme="comment-devenir-genial" />
</Layout>