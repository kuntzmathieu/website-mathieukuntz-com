---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/main/Navbar.astro';
import PromoBanner from '../components/main/PromoBanner.astro';
import Hero from '../components/main/Hero.astro';
import Activites from '../components/main/Activites.astro';
import QuiJeSuis from '../components/main/QuiJeSuis.astro';
import DiscoverFlow from '../components/main/DiscoverFlow.astro';
import Schedule from '../components/main/Schedule.astro';
import Features from '../components/main/Features.astro';
import Teachers from '../components/main/Teachers.astro';
import Pricing from '../components/main/Pricing.astro';
import Gallery from '../components/main/Gallery.astro';
import Contact from '../components/main/Contact.astro';
import Footer from '../components/main/Footer.astro';
---

<MainLayout
  title="Mathieu Kuntz — Grandir et embellir, concrètement"
  description="Spectacle, thérapie, stages, enseignement. Multi-potentiel au service du votre."
>
  <Navbar />
  <PromoBanner />
  <main class="pt-16">
    <Hero />
    <Activites />
    <QuiJeSuis />
    <DiscoverFlow />
    <Schedule />
    <Features />
    <Teachers />
    <Pricing />
    <Gallery />
    <Contact />
  </main>
  <Footer />
</MainLayout>
