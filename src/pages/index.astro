---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SocialProof from '../components/SocialProof.astro';
import CTA from '../components/CTA.astro';

const spectacles = [
  {
    slug: 'petit-prince-hypnotiseur',
    title: 'Le Petit Prince Hypnotiseur',
    tagline: 'Hypnose de scène, émerveillement, participation',
    shortDesc: 'Le Petit Prince hypnotise des volontaires du public et les emmène voyager de planète en planète. Le conte le plus célèbre du monde, réinventé par l\'hypnose.',
    emoji: '&#x1F451;',
  },
  {
    slug: 'petit-prince-immersif',
    title: "Le Petit Prince — L'expérience immersive",
    tagline: "Hypnose immersive, musique, émotion",
    shortDesc: 'Fermez les yeux. Vous êtes sur la planète B612. Une version inédite du Petit Prince, revisitée par Mathieu, où tout le public rejoint le Petit Prince dans son voyage.',
    emoji: '&#x2728;',
  },
  {
    slug: 'vie-de-reve',
    title: 'Une Vie de Rêve',
    tagline: 'Hypnose, musique, histoires vraies',
    shortDesc: "Comment faire se rapprocher rêve et réalité ? Un spectacle quelque part entre les deux. Hypnose, musique et anecdotes vraies. M'enfin vous verrez...",
    emoji: '&#x1F319;',
  },
  {
    slug: 'comment-devenir-genial',
    title: 'Comment devenir génial',
    tagline: 'Conte, conférence, hypnose immersive',
    shortDesc: 'La réponse n\'est pas ce que vous croyez. Des histoires vraies, de l\'hypnose, et la preuve que vous l\'êtes déjà.',
    emoji: '&#x1F4AB;',
  },
];
---

<Layout
  title="Spectacles Mathieu Kuntz — Hypnose, magie et sincérité à Grenoble"
  description="4 spectacles uniques à Grenoble. Hypnose, musique, magie et histoires vraies. Découvrez l'expérience qui vous appelle."
>
  <Hero
    title="Des spectacles qui changent la façon dont vous vous voyez"
    tagline="Hypnose, musique, magie et histoires vraies — 4 expériences uniques à Grenoble. Lequel vous appelle ?"
  />

  <section class="spectacles section">
    <div class="container">
      <h2 class="fade-in">Choisissez votre expérience</h2>
      <p class="spectacles-subtitle fade-in">4 spectacles, 4 univers. Un même savoir-faire.</p>
      <div class="spectacles-grid">
        {spectacles.map((s) => (
          <a href={`/${s.slug}`} class="spectacle-card fade-in">
            <span class="card-emoji" set:html={s.emoji} />
            <h3>{s.title}</h3>
            <p class="card-tagline">{s.tagline}</p>
            <p class="card-desc">{s.shortDesc}</p>
            <span class="card-link">Découvrir &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <SocialProof />

  <CTA />
</Layout>

<style>
  .spectacles h2 {
    text-align: center;
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .spectacles-subtitle {
    text-align: center;
    color: var(--text-secondary);
    margin-bottom: 3rem;
  }

  .spectacles-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .spectacle-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 2rem;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .spectacle-card:hover {
    border-color: var(--accent-gold);
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(201, 168, 76, 0.15);
  }

  .card-emoji {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .spectacle-card h3 {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .card-tagline {
    color: var(--accent-gold);
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .card-desc {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }

  .card-link {
    color: var(--accent-gold);
    font-weight: 600;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .spectacles-grid {
      grid-template-columns: 1fr;
    }
  }
</style>