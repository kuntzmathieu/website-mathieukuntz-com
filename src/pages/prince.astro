---
import PrinceLayout from '../layouts/PrinceLayout.astro';
import Navbar from '../components/prince/Navbar.astro';
import Hero from '../components/prince/Hero.astro';
import Experience from '../components/prince/Experience.astro';
import Deroule from '../components/prince/Deroule.astro';
import PourQui from '../components/prince/PourQui.astro';
import Artiste from '../components/prince/Artiste.astro';
import Infos from '../components/prince/Infos.astro';
import FAQ from '../components/prince/FAQ.astro';
import Reservation from '../components/prince/Reservation.astro';
import Inscription from '../components/prince/Inscription.astro';
import FinalCTA from '../components/prince/FinalCTA.astro';
import Footer from '../components/prince/Footer.astro';
import MobileCTABar from '../components/prince/MobileCTABar.astro';
---

<PrinceLayout
  title="PRINCE — Spectacle immersif sous hypnose | Vif, 11 juillet 2026"
  description="Fermez les yeux et vivez le conte initiatique le plus célèbre au monde à la première personne. Musique live, hypnose douce."
>
  <Navbar />

  <!-- Bandeau feedback post-spectacle -->
  <a href="/prince/feedback?from=page_web" class="block w-full bg-[#E8C76A] text-[#0A0A14] py-4 px-6 text-center font-semibold text-base md:text-lg hover:bg-white transition-colors duration-300">
    Vous avez vu le spectacle ? Partagez votre avis en 3 minutes →
  </a>

  <Hero />
  <Experience />
  <Deroule />
  <PourQui />
  <Artiste />
  <Infos />
  <FAQ />
  <Reservation />
  <Inscription />
  <FinalCTA />
  <Footer />
  <MobileCTABar />
</PrinceLayout>
