---
import PrinceLayout from '../../layouts/PrinceLayout.astro';
---

<PrinceLayout
  title="Place offerte — PRINCE | Mathieu Kuntz"
  description="Suite au spectacle PRINCE du 11 juillet au Vif, recevez une place offerte pour la prochaine représentation."
>
  <section class="py-16 px-6 md:px-12 min-h-[80vh] relative">
    <div class="max-w-2xl mx-auto w-full space-y-12">

      <!-- Header -->
      <div class="text-center space-y-4">
        <span class="inline-block px-4 py-1.5 rounded-full bg-[#E8C76A]/10 border border-[#E8C76A]/30 text-[#E8C76A] text-xs font-bold uppercase tracking-widest">
          Place offerte
        </span>
        <h1 class="text-3xl md:text-5xl font-serif tracking-tight text-[#F2EFEA]">
          Une place pour la prochaine représentation.
        </h1>
        <p class="text-base md:text-lg text-[#F2EFEA]/85 font-light leading-relaxed max-w-xl mx-auto">
          Les conditions d'accueil du spectacle PRINCE ce 11 juillet au Vif n'ont pas
          été à la hauteur de l'expérience que je voulais vous offrir. En dédommagement,
          je vous offre une place pour la prochaine représentation, dans de meilleures
          conditions. Laissez-moi vos informations : vous recevrez un code nominatif
          dès que les nouvelles dates seront annoncées.
        </p>
        <p class="text-sm text-white/50 font-light leading-relaxed max-w-lg mx-auto">
          Mathieu KUNTZ
        </p>
      </div>

      <!-- Form -->
      <form id="offre-form" class="space-y-16">

        <!-- BLOC A — Votre billet -->
        <div class="space-y-8">
          <h2 class="text-sm font-bold uppercase tracking-widest text-[#E8C76A] border-b border-[#E8C76A]/20 pb-3">
            Votre billet
          </h2>

          <div class="req-block space-y-3">
            <label class="block text-base md:text-lg text-[#F2EFEA] font-medium" for="numero_billet">
              Numéro de billet <span class="text-[#E8C76A]">*</span>
            </label>
            <p class="text-sm text-white/40 font-light">Il figure sur votre billet PDF et votre email de confirmation (format PRINCE110726VIF-0001).</p>
            <input type="text" name="numero_billet" id="numero_billet" required class="w-full px-4 py-3 bg-white/[0.02] border border-white/10 rounded-lg text-[#F2EFEA] placeholder-white/30 font-light outline-none focus:border-[#E8C76A]/40 transition-colors" placeholder="PRINCE110726VIF-0001" />
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="req-block space-y-3">
              <label class="block text-base md:text-lg text-[#F2EFEA] font-medium" for="nom_billet">
                Nom du billet <span class="text-[#E8C76A]">*</span>
              </label>
              <input type="text" name="nom_billet" id="nom_billet" required class="w-full px-4 py-3 bg-white/[0.02] border border-white/10 rounded-lg text-[#F2EFEA] placeholder-white/30 font-light outline-none focus:border-[#E8C76A]/40 transition-colors" placeholder="Nom" />
            </div>
            <div class="req-block space-y-3">
              <label class="block text-base md:text-lg text-[#F2EFEA] font-medium" for="prenom_billet">
                Prénom du billet <span class="text-[#E8C76A]">*</span>
              </label>
              <input type="text" name="prenom_billet" id="prenom_billet" required class="w-full px-4 py-3 bg-white/[0.02] border border-white/10 rounded-lg text-[#F2EFEA] placeholder-white/30 font-light outline-none focus:border-[#E8C76A]/40 transition-colors" placeholder="Prénom" />
            </div>
          </div>

          <div class="req-block space-y-3">
            <label class="block text-base md:text-lg text-[#F2EFEA] font-medium" for="place_salle">
              Où étiez-vous assis dans la salle ? <span class="text-[#E8C76A]">*</span>
            </label>
            <textarea name="place_salle" id="place_salle" rows="2" required class="w-full px-4 py-3 bg-white/[0.02] border border-white/10 rounded-lg text-[#F2EFEA] placeholder-white/30 font-light outline-none focus:border-[#E8C76A]/40 transition-colors resize-none" placeholder="Rang, côté, près de la scène, au fond..."></textarea>
          </div>
        </div>

        <!-- BLOC B — Pour préparer la prochaine -->
        <div class="space-y-8">
          <h2 class="text-sm font-bold uppercase tracking-widest text-[#E8C76A] border-b border-[#E8C76A]/20 pb-3">
            Pour préparer la prochaine
          </h2>

          <div class="req-block space-y-3">
            <label class="block text-base md:text-lg text-[#F2EFEA] font-medium" for="condition_satisfaction">
              Au-delà de la qualité de l'accueil, vous ressortirez ravis du prochain spectacle Prince si... <span class="text-[#E8C76A]">*</span>
            </label>
            <textarea name="condition_satisfaction" id="condition_satisfaction" rows="3" required class="w-full px-4 py-3 bg-white/[0.02] border border-white/10 rounded-lg text-[#F2EFEA] placeholder-white/30 font-light outline-none focus:border-[#E8C76A]/40 transition-colors resize-none" placeholder="..."></textarea>
          </div>

          <div class="space-y-3">
            <label class="block text-base md:text-lg text-[#F2EFEA] font-medium" for="autre_important">
              Autre chose d'important à dire, suggérer ou que vous attendriez ?
            </label>
            <textarea name="autre_important" id="autre_important" rows="3" class="w-full px-4 py-3 bg-white/[0.02] border border-white/10 rounded-lg text-[#F2EFEA] placeholder-white/30 font-light outline-none focus:border-[#E8C76A]/40 transition-colors resize-none" placeholder="Libre..."></textarea>
          </div>
        </div>

        <!-- BLOC C — Contact -->
        <div class="space-y-8">
          <h2 class="text-sm font-bold uppercase tracking-widest text-[#E8C76A] border-b border-[#E8C76A]/20 pb-3">
            Pour vous recontacter
          </h2>

          <div class="req-block space-y-3">
            <label class="block text-base md:text-lg text-[#F2EFEA] font-medium" for="email">
              Email <span class="text-[#E8C76A]">*</span>
            </label>
            <input type="email" name="email" id="email" required class="w-full px-4 py-3 bg-white/[0.02] border border-white/10 rounded-lg text-[#F2EFEA] placeholder-white/30 font-light outline-none focus:border-[#E8C76A]/40 transition-colors" placeholder="vous@email.com" />
            <p class="text-xs text-white/45 font-light leading-relaxed">
              J'autorise Mathieu KUNTZ à utiliser mes informations pour traiter ma demande et me tenir informé des prochains spectacles.
            </p>
          </div>
        </div>

        <!-- Submit -->
        <div>
          <button type="submit" id="submit-btn" class="w-full px-10 py-5 bg-[#E8C76A] text-[#0A0A14] font-bold text-sm tracking-widest uppercase rounded-full hover:bg-white hover:scale-[1.02] transition-all duration-300 shadow-xl shadow-[#E8C76A]/20">
            Enregistrer
          </button>
        </div>
      </form>

      <!-- Success state -->
      <div id="success" class="hidden text-center space-y-6 py-16">
        <iconify-icon icon="solar:check-circle-bold" class="text-6xl text-[#E8C76A]"></iconify-icon>
        <h2 class="text-3xl md:text-4xl font-serif text-[#F2EFEA]">Merci !</h2>
        <p class="text-base md:text-lg text-[#F2EFEA]/85 font-light leading-relaxed max-w-md mx-auto">
          Vos informations ont bien été enregistrées. Vous serez tenu informé de la prochaine date de spectacle dès sa programmation et recevrez votre code pour votre place offerte.
        </p>
      </div>

      <!-- Error state -->
      <div id="error" class="hidden text-center space-y-4 py-16">
        <iconify-icon icon="solar:close-circle-linear" class="text-5xl text-red-400"></iconify-icon>
        <h2 class="text-2xl font-serif text-[#F2EFEA]">Une erreur est survenue</h2>
        <p id="error-msg" class="text-[#F2EFEA]/60 font-light"></p>
        <button type="button" id="retry-btn" class="inline-block px-6 py-3 border border-white/10 rounded-full text-sm text-[#E8C76A] hover:bg-white/5 transition-colors">Réessayer</button>
      </div>
    </div>
  </section>
</PrinceLayout>

<style is:global>
  .req-block {
    border-radius: 1rem;
    padding: 1.25rem;
    background: rgba(232, 199, 106, 0.05);
    border: 1px solid rgba(232, 199, 106, 0.15);
    box-shadow: 0 0 24px rgba(232, 199, 106, 0.04);
  }
</style>

<script is:inline>
  const SOURCE = new URLSearchParams(window.location.search).get('from') === 'email' ? 'email' : 'page_web';

  document.getElementById('offre-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submit-btn');
    btn.disabled = true;
    btn.textContent = 'Envoi...';

    const form = e.target;
    const getText = (name) => form.querySelector('[name="' + name + '"]') ? form.querySelector('[name="' + name + '"]').value.trim() : '';

    const payload = {
      numero_billet: getText('numero_billet'),
      nom_billet: getText('nom_billet'),
      prenom_billet: getText('prenom_billet'),
      place_salle: getText('place_salle'),
      condition_satisfaction: getText('condition_satisfaction'),
      autre_important: getText('autre_important'),
      email: getText('email'),
      source_soumission: SOURCE,
    };

    try {
      const res = await fetch('/api/submit-place-offerte', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Erreur serveur');

      form.style.display = 'none';
      document.getElementById('success').classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    } catch (err) {
      document.getElementById('error-msg').textContent = err.message;
      document.getElementById('error').classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Enregistrer';
    }
  });

  document.getElementById('retry-btn').addEventListener('click', () => {
    document.getElementById('error').classList.add('hidden');
    document.getElementById('submit-btn').disabled = false;
    document.getElementById('submit-btn').textContent = 'Enregistrer';
  });
</script>
