---
import PrinceLayout from '../../layouts/PrinceLayout.astro';
---

<PrinceLayout
  title="Admin PRINCE - Connexion | Mathieu Kuntz"
  description="Connexion admin pour le spectacle PRINCE."
>
  <section class="py-24 px-6 md:px-12 min-h-[80vh] flex items-center justify-center">
    <div class="max-w-lg mx-auto w-full space-y-8">
      <div class="text-center space-y-4">
        <span class="text-sm uppercase tracking-widest text-[#E8C76A] font-bold">Admin</span>
        <h1 class="text-4xl md:text-6xl font-serif tracking-tight text-[#F2EFEA]">PRINCE</h1>
        <p class="text-[#F2EFEA]/70 font-light">Connectez-vous pour gérer les ventes et le check-in.</p>
      </div>

      <form id="admin-login" class="rounded-2xl bg-white/[0.03] border border-white/10 p-8 space-y-5">
        <div>
          <label class="text-xs uppercase tracking-widest text-white/50 block mb-2">Token admin</label>
          <input id="admin-token" type="password" autocomplete="current-password" required class="w-full px-4 py-3 bg-white/[0.02] border border-white/10 rounded-lg text-[#F2EFEA] outline-none focus:border-[#E8C76A]/40 transition-colors" />
        </div>
        <p id="admin-message" class="hidden text-sm"></p>
        <button type="submit" class="w-full px-8 py-4 bg-[#E8C76A] text-[#0A0A14] font-bold text-sm tracking-widest uppercase rounded-full hover:bg-white hover:scale-[1.02] transition-all duration-300">
          Se connecter
        </button>
      </form>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-center">
        <a href="/prince/admin-vente" class="px-5 py-3 rounded-full border border-white/10 text-sm uppercase tracking-widest text-[#F2EFEA] hover:border-[#E8C76A]/40 hover:bg-white/5 transition-all">Vente admin</a>
        <a href="/prince/admin-checkin" class="px-5 py-3 rounded-full border border-white/10 text-sm uppercase tracking-widest text-[#F2EFEA] hover:border-[#E8C76A]/40 hover:bg-white/5 transition-all">Check-in</a>
      </div>
    </div>
  </section>

  <script is:inline>
    const savedToken = localStorage.getItem('prince_admin_token') || '';
    const tokenInput = document.getElementById('admin-token');
    const message = document.getElementById('admin-message');
    tokenInput.value = savedToken;

    document.getElementById('admin-login').addEventListener('submit', async (event) => {
      event.preventDefault();
      const token = tokenInput.value.trim();
      message.classList.remove('hidden');
      message.className = 'text-sm text-white/50';
      message.textContent = 'Vérification...';
      try {
        const res = await fetch('/api/admin/ping', { headers: { Authorization: `Bearer ${token}` } });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Accès refusé');
        localStorage.setItem('prince_admin_token', token);
        message.className = 'text-sm text-[#E8C76A]';
        message.textContent = 'Connexion validée.';
        window.location.href = '/prince/admin-vente';
      } catch (err) {
        message.className = 'text-sm text-red-400';
        message.textContent = err.message;
      }
    });
  </script>
</PrinceLayout>
