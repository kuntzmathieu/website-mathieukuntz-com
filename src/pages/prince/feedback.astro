<script is:inline>
  const SOURCE = new URLSearchParams(window.location.search).get('from') === 'email' ? 'email' : 'qr_site';

  // Q1 stars
  const stars = document.querySelectorAll('.star-btn');
  let q1Value = 0;
  stars.forEach(btn => {
    btn.addEventListener('click', () => {
      q1Value = parseInt(btn.dataset.star, 10);
      document.getElementById('q1-value').value = q1Value;
      stars.forEach((s, i) => {
        s.classList.toggle('text-[#E8C76A]', i < q1Value);
        s.classList.toggle('text-white/20', i >= q1Value);
      });
    });
  });

  // Q6 grille stars
  document.querySelectorAll('.grille-star').forEach(btn => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.grille;
      const val = parseInt(btn.dataset.val, 10);
      const row = btn.closest('.grille-row');
      row.dataset.value = val;
      document.querySelectorAll('.grille-star[data-grille="' + key + '"]').forEach((star, i) => {
        star.classList.toggle('selected', i < val);
      });
    });
  });

  // Q11 NPS
  document.querySelectorAll('.nps-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.nps;
      const val = parseInt(btn.dataset.val, 10);
      document.querySelectorAll('.nps-btn[data-nps="' + key + '"]').forEach(n => n.classList.remove('selected'));
      btn.classList.add('selected');
      const hiddenId = 'nps-' + key.replace('nps_', '') + '-value';
      document.getElementById(hiddenId).value = val;
    });
  });

  // Submit
  document.getElementById('feedback-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submit-btn');
    btn.disabled = true;
    btn.textContent = 'Envoi...';

    const form = e.target;
    const grille = {};
    document.querySelectorAll('.grille-row').forEach(row => {
      grille[row.dataset.key] = row.dataset.value || '';
    });

    const getChecked = (name) => Array.from(form.querySelectorAll('input[name="' + name + '"]:checked')).map(i => i.value);
    const getText = (name) => form.querySelector('[name="' + name + '"]') ? form.querySelector('[name="' + name + '"]').value.trim() : '';

    const payload = {
      note: document.getElementById('q1-value').value,
      deja_vu_hypnose: form.querySelector('input[name="deja_vu_hypnose"]:checked') ? form.querySelector('input[name="deja_vu_hypnose"]:checked').value : '',
      connait_petit_prince: form.querySelector('input[name="connait_petit_prince"]:checked') ? form.querySelector('input[name="connait_petit_prince"]:checked').value : '',
      attentes: getText('attentes'),
      ce_qui_reste: getText('ce_qui_reste'),
      grille: grille,
      emotions: getChecked('emotions'),
      emotions_autre: getText('emotions_autre'),
      moment_decrochage: getText('moment_decrochage'),
      rythme: form.querySelector('input[name="rythme"]:checked') ? form.querySelector('input[name="rythme"]:checked').value : '',
      prix_percu: form.querySelector('input[name="prix_percu"]:checked') ? form.querySelector('input[name="prix_percu"]:checked').value : '',
      nps_recommander: document.getElementById('nps-recommander-value').value,
      nps_revenir: document.getElementById('nps-revenir-value').value,
      decouverte: getChecked('decouverte'),
      decouverte_autre: getText('decouverte_autre'),
      motivation: getChecked('motivation'),
      motivation_autre: getText('motivation_autre'),
      description_ami: getText('description_ami'),
      interets: getChecked('interets'),
      interets_autre: getText('interets_autre'),
      amelioration: getText('amelioration'),
      nom_contact: getText('nom_contact'),
      prenom_contact: getText('prenom_contact'),
      email_contact: getText('email_contact'),
      optin_newsletter: form.querySelector('input[name="optin_newsletter"]').checked,
      source_soumission: SOURCE,
    };

    try {
      const res = await fetch('/api/submit-feedback', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Erreur serveur');

      form.style.display = 'none';
      document.getElementById('success').classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    } catch (err) {
      document.getElementById('error-msg').textContent = err.message;
      document.getElementById('error').classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Envoyer mon avis';
    }
  });

  document.getElementById('retry-btn').addEventListener('click', () => {
    document.getElementById('error').classList.add('hidden');
    document.getElementById('submit-btn').disabled = false;
    document.getElementById('submit-btn').textContent = 'Envoyer mon avis';
  });
</script>
