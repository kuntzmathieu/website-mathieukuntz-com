---
import PrinceLayout from '../../layouts/PrinceLayout.astro';
---

<PrinceLayout
  title="Check-in admin - PRINCE | Mathieu Kuntz"
  description="Valider les billets à l'entrée du spectacle PRINCE."
>
  <section class="py-20 px-6 md:px-12 min-h-screen">
    <div class="max-w-6xl mx-auto space-y-8">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="space-y-3">
          <span class="text-sm uppercase tracking-widest text-[#E8C76A] font-bold">Admin</span>
          <h1 class="text-4xl md:text-6xl font-serif tracking-tight text-[#F2EFEA]">Check-in</h1>
          <p class="text-[#F2EFEA]/70 font-light max-w-2xl">Recherchez un billet par numéro, nom ou prénom, puis validez l'entrée.</p>
        </div>
        <div class="flex gap-3">
          <a href="/prince/admin-vente" class="px-5 py-3 rounded-full border border-white/10 text-xs uppercase tracking-widest text-[#F2EFEA] hover:border-[#E8C76A]/40 hover:bg-white/5 transition-all">Vente admin</a>
          <a href="/prince/admin-login" class="px-5 py-3 rounded-full border border-white/10 text-xs uppercase tracking-widest text-[#E8C76A] hover:border-[#E8C76A]/40 hover:bg-white/5 transition-all">Login</a>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="p-5 rounded-2xl bg-white/[0.03] border border-white/10">
          <p class="text-xs uppercase tracking-widest text-white/40">Total billets</p>
          <p id="stat-total" class="text-3xl font-serif text-[#F2EFEA]">0</p>
          <p class="text-xs text-red-400 font-light mt-1">Dont non réglé : <span id="stat-unpaid" class="font-bold">0</span></p>
        </div>
        <div class="p-5 rounded-2xl bg-white/[0.03] border border-white/10">
          <p class="text-xs uppercase tracking-widest text-white/40">Entrés</p>
          <p id="stat-checked" class="text-3xl font-serif text-[#E8C76A]">0</p>
        </div>
        <div class="p-5 rounded-2xl bg-white/[0.03] border border-white/10">
          <p class="text-xs uppercase tracking-widest text-white/40">Restants</p>
          <p id="stat-pending" class="text-3xl font-serif text-[#F2EFEA]">0</p>
        </div>
      </div>

      <form id="checkin-form" class="rounded-2xl bg-white/[0.03] border border-white/10 p-6 md:p-8 space-y-5">
        <label class="text-xs uppercase tracking-widest text-white/50 block">Numéro de billet</label>
        <div class="flex flex-col md:flex-row gap-3">
          <input id="ticket-number" type="text" inputmode="numeric" placeholder="Ex: 8 ou 12" class="flex-1 px-4 py-4 bg-white/[0.02] border border-white/10 rounded-lg text-[#F2EFEA] outline-none focus:border-[#E8C76A]/40 transition-colors uppercase tracking-wider" />
          <button type="submit" class="px-8 py-4 bg-[#E8C76A] text-[#0A0A14] font-bold text-sm tracking-widest uppercase rounded-full hover:bg-white hover:scale-[1.02] transition-all duration-300">Valider</button>
        </div>
        <p id="checkin-message" class="hidden text-sm"></p>
      </form>

      <div class="rounded-2xl bg-white/[0.03] border border-white/10 p-6 md:p-8 space-y-5">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
          <h2 class="text-2xl font-serif text-[#F2EFEA]">Liste des billets</h2>
          <input id="search" type="search" placeholder="Rechercher nom, prénom, numéro..." class="w-full md:w-80 px-4 py-3 bg-white/[0.02] border border-white/10 rounded-lg text-[#F2EFEA] outline-none focus:border-[#E8C76A]/40 transition-colors" />
        </div>
        <div id="tickets-list" class="space-y-3"></div>
      </div>
    </div>
  </section>

  <script is:inline>
    const token = localStorage.getItem('prince_admin_token') || '';
    const list = document.getElementById('tickets-list');
    const message = document.getElementById('checkin-message');
    const searchInput = document.getElementById('search');
    let billets = [];

    if (!token) window.location.href = '/prince/admin-login';

    function normalize(value) {
      return String(value || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
    }

    function renderStats() {
      document.getElementById('stat-total').textContent = billets.length;
      document.getElementById('stat-checked').textContent = billets.filter(b => Boolean(b.checkin)).length;
      document.getElementById('stat-pending').textContent = billets.filter(b => !Boolean(b.checkin)).length;
      const unpaidEl = document.getElementById('stat-unpaid');
      if (unpaidEl) unpaidEl.textContent = billets.filter(b => b.paiement_commande === 'à encaisser').length;
    }

    function renderList() {
      const q = normalize(searchInput.value);
      const filtered = billets.filter((b) => normalize(`${b.numero_billet} ${b.prenom} ${b.nom} ${b.type}`).includes(q));
      if (filtered.length === 0) {
        list.innerHTML = '<p class="text-white/40 font-light">Aucun billet trouvé.</p>';
        return;
      }
      list.innerHTML = filtered.map((b) => {
        const actionBtn = b.checkin
          ? `<button type="button" data-undo="${b.numero_billet}" class="px-5 py-3 rounded-full text-xs uppercase tracking-widest font-bold bg-red-500/10 border border-red-500/30 text-red-400 hover:bg-red-500/20 transition-all">Annuler entrée</button>`
          : `<button type="button" data-checkin="${b.numero_billet}" class="px-5 py-3 rounded-full text-xs uppercase tracking-widest font-bold bg-[#E8C76A] text-[#0A0A14] hover:bg-white transition-all">Valider entrée</button>`;
        return `
        <div class="p-4 rounded-xl border ${b.checkin ? 'border-[#E8C76A]/30 bg-[#E8C76A]/5' : 'border-white/10 bg-white/[0.02]'} flex flex-col md:flex-row md:items-center justify-between gap-4">
          <div>
            <p class="font-mono text-sm ${b.checkin ? 'text-[#E8C76A]' : 'text-[#F2EFEA]'}">${b.numero_billet}</p>
            <p class="text-lg font-serif text-[#F2EFEA]">${b.prenom || ''} ${b.nom || ''}</p>
            <p class="text-sm text-white/50">${b.type || ''} · ${b.prix_paye || 0}€ · ${b.email_personne || 'sans email'}</p>
          </div>
          ${actionBtn}
        </div>`;
      }).join('');
      list.querySelectorAll('[data-checkin]').forEach((button) => {
        button.addEventListener('click', () => checkin(button.dataset.checkin));
      });
      list.querySelectorAll('[data-undo]').forEach((button) => {
        button.addEventListener('click', () => undoCheckin(button.dataset.undo));
      });
    }

    async function loadBillets() {
      list.innerHTML = '<p class="text-white/40 font-light">Chargement...</p>';
      try {
        const res = await fetch('/api/admin/list-billets', { headers: { Authorization: `Bearer ${token}` } });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Erreur');
        billets = data.billets || [];
        renderStats();
        renderList();
      } catch (err) {
        list.innerHTML = `<p class="text-red-400">${err.message}</p>`;
      }
    }

    async function checkin(numero) {
      let query = numero;
      if (/^\d{1,4}$/.test(query.trim())) {
        query = `PRINCE110726VIF-${String(parseInt(query.trim())).padStart(4, '0')}`;
      }
      message.classList.remove('hidden');
      message.className = 'text-sm text-white/50';
      message.textContent = 'Validation...';
      try {
        const res = await fetch('/api/admin/checkin', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
          body: JSON.stringify({ numero_billet: query }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Erreur');
        message.className = data.already_checked ? 'text-sm text-orange-300' : 'text-sm text-[#E8C76A]';
        message.textContent = data.already_checked ? 'Billet déjà validé.' : `Entrée validée : ${data.billet.prenom || ''} ${data.billet.nom || ''}`;
        await loadBillets();
      } catch (err) {
        message.className = 'text-sm text-red-400';
        message.textContent = err.message;
      }
    }

    async function undoCheckin(numero) {
      let query = numero;
      if (/^\d{1,4}$/.test(query.trim())) {
        query = `PRINCE110726VIF-${String(parseInt(query.trim())).padStart(4, '0')}`;
      }
      message.classList.remove('hidden');
      message.className = 'text-sm text-white/50';
      message.textContent = 'Annulation...';
      try {
        const res = await fetch('/api/admin/undo-checkin', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
          body: JSON.stringify({ numero_billet: query }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Erreur');
        message.className = 'text-sm text-red-400';
        message.textContent = `Entrée annulée : ${data.billet.prenom || ''} ${data.billet.nom || ''}`;
        await loadBillets();
      } catch (err) {
        message.className = 'text-sm text-red-400';
        message.textContent = err.message;
      }
    }

    document.getElementById('checkin-form').addEventListener('submit', (event) => {
      event.preventDefault();
      const input = document.getElementById('ticket-number');
      const value = input.value.trim();
      if (value) checkin(value);
      input.value = '';
    });

    searchInput.addEventListener('input', renderList);
    loadBillets();
  </script>
</PrinceLayout>
