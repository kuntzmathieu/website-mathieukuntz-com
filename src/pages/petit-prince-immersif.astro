---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Description from '../components/Description.astro';
import VideoTeaser from '../components/VideoTeaser.astro';
import SpectaclePhotos from '../components/SpectaclePhotos.astro';
import ForYou from '../components/ForYou.astro';
import About from '../components/About.astro';
import Steps from '../components/Steps.astro';
import SocialProof from '../components/SocialProof.astro';
import Faq from '../components/Faq.astro';
import CTA from '../components/CTA.astro';

const description = `
<p>Mathieu est né en 2000, pas en 1900. Et il n'est pas aviateur, mais moniteur de ski. Mais lui aussi a rencontré le Petit Prince, et lui aussi alors qu'il était perdu dans un désert.</p>

<p>Mais dans un désert... de neige, et de sens. Au milieu de ses montagnes natales et de ses questions existentielles, 100 ans plus tard.</p>

<p>Alors Mathieu nous raconte à son tour ce conte mythique, enrichi de ses réflexions actuelles et dans une version inédite mêlant théâtre, musique et hypnose immersive. Là où l'hypnose de scène met des volontaires au premier plan, ici c'est <em>tout le public</em> qui rejoint le Petit Prince dans son monde — yeux fermés, guidé par l'hypnose et la musique — pour faire à son tour le voyage et les découvertes.</p>

<p>Venez vivre en direct les (nouvelles) aventures du Petit Prince, pour (re)trouver la sagesse à travers les yeux d'un (grand) enfant, sur notre planète d'aujourd'hui.</p>
`;

const forYouItems = [
  "Vous voulez vivre une expérience, pas juste en regarder une",
  "Le Petit Prince vous touche et vous voulez le retrouver autrement",
  "L'idée d'être guidé par l'hypnose et la musique vous intrigue",
  "Vous cherchez un moment de poésie, d'émerveillement et de douceur",
  "Vous voulez repartir avec quelque chose qui reste longtemps",
];

const steps = [
  {
    number: "1",
    title: "Fermez les yeux",
    description: "Vous n'êtes plus dans une salle. Vous êtes sur la planète B612. L'hypnose guidée et la musique vous plongent dans l'univers du conte."
  },
  {
    number: "2",
    title: "Le désert de neige et de sens",
    description: "Mathieu raconte sa rencontre avec le Petit Prince — pas dans le désert de sable, mais dans un désert de neige et de sens. 100 ans plus tard, les questions sont les mêmes, les réponses résonnent autrement."
  },
  {
    number: "3",
    title: "De planète en planète",
    description: "Le Roi et son besoin de pouvoir, le Vaniteux et son ego, le Businessman et ses chiffres, l'Allumeur de réverbères et sa routine — vous les rencontrez comme le Petit Prince les a rencontrés. Les yeux fermés, vous êtes dans l'histoire."
  },
  {
    number: "4",
    title: "La rose, le renard, l'essentiel",
    description: "Les sagesses du conte revisitée : l'apprivoisement, l'essentiel invisible pour les yeux, le voyage vers chez soi. Vécues de l'intérieur, pas racontées de l'extérieur."
  },
  {
    number: "5",
    title: "Le retour",
    description: "On ouvre les yeux. On est de retour. Mais quelque chose a changé. Une sagesse enfouie qu'on avait oubliée, et qu'on retrouve."
  },
];

const faqs = [
  {
    question: "C'est quoi un spectacle immersif sous hypnose ?",
    answer: "Tout le public participe — vous fermez les yeux, et vous êtes guidé dans une histoire. Pas besoin de monter sur scène. L'hypnose immersive vous permet de vivre le conte de l'intérieur, comme si vous y étiez."
  },
  {
    question: "En quoi c'est différent de l'hypnose de scène classique ?",
    answer: "Dans l'hypnose de scène, des volontaires montent sur scène et font des choses spectaculaires devant le public. Ici, c'est tout le public qui participe depuis sa place — yeux fermés, vous êtes guidé dans le conte. Vous vivez l'aventure, vous ne la regardez pas."
  },
  {
    question: "Je connais déjà le Petit Prince, est-ce que c'est différent ?",
    answer: "Complètement. C'est une version inédite, revisitée par Mathieu. Pas l'histoire classique — une version enrichie de réflexions actuelles, mêlant théâtre, musique et hypnose immersive. Même si vous connaissez le conte par cœur, le vivre de l'intérieur est une toute autre chose."
  },
  {
    question: "Est-ce que c'est dangereux ?",
    answer: "Pas du tout. L'hypnose guidée est un état de relaxation profonde qu'on expérimente naturellement tous les jours. C'est doux, sécurisant, et vous gardez le contrôle à tout moment."
  },
];

const photos = [
  { src: "", alt: "Mathieu en spectacle — hypnose immersive" },
  { src: "", alt: "Public les yeux fermés, guidé par la musique" },
];
---

<Layout
  title="Le Petit Prince — L'expérience immersive — Spectacle à Grenoble"
  description="Fermez les yeux. Vous êtes sur la planète B612. Un conte immersif sous hypnose et en musique, revisitée par Mathieu. Grenoble."
>
  <Hero
    title="Le Petit Prince — L'expérience immersive"
    tagline="Fermez les yeux. Vous êtes sur la planète B612. Un conte immersif sous hypnose et en musique, où tout le public rejoint le Petit Prince dans son voyage."
    theme="petit-prince-immersif"
    heroImage="/hero-petit-prince.png"
  />

  <Description content={description} />

  <VideoTeaser />

  <ForYou items={forYouItems} title="Ce spectacle est pour vous si..." />

  <SpectaclePhotos photos={photos} />

  <About />

  <Steps steps={steps} />

  <SocialProof />

  <Faq faqs={faqs} />

  <CTA theme="petit-prince-immersif" />
</Layout>