---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Rêve ! — Spectacle sous hypnose | Mathieu Kuntz"
  description="Un spectacle entre rêve éveillé, histoires vraies et hypnose, pour rapprocher ce qu'on imagine de ce qu'on ose vivre. Grenoble."
  currentPage="reve"
>
  <section class="hero">
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <h1 class="hero-title fade-in">
        <span class="hero-main">Rêve !</span>
        <span class="hero-sub">Spectacle sous hypnose</span>
      </h1>
      <p class="hero-tagline fade-in">Un spectacle entre rêve éveillé, histoires vraies et hypnose, pour rapprocher ce qu'on imagine de ce qu'on ose vivre.</p>
      <form class="hero-form fade-in" action="https://formspree.io/f/placeholder" method="POST">
        <input type="hidden" name="theme" value="reve" />
        <div class="hero-form-row">
          <input type="email" name="email" placeholder="Être informé des prochaines dates" required class="hero-email" />
          <button type="submit" class="btn-cta">M'inscrire</button>
        </div>
        <p class="form-note">Pas de spam. Promis.</p>
      </form>
    </div>
  </section>

  <section class="content section">
    <div class="container content-grid">
      <div class="content-left fade-in">
        <h2>Prochaines représentations</h2>
        <p class="dates-place">Grenoble — dates à venir</p>

        <form class="email-form" action="https://formspree.io/f/placeholder" method="POST">
          <input type="hidden" name="theme" value="reve" />
          <div class="form-row">
            <input type="email" name="email" placeholder="Je veux être informé des prochaines dates" required class="email-input" />
            <button type="submit" class="btn-cta">M'inscrire</button>
          </div>
          <p class="form-note">Pas de spam. Promis.</p>
        </form>

        <h2>Réservation</h2>
        <p class="booking-desc">Prochaines représentations prévues à Grenoble. Pour être informé des prochaines dates, laissez votre email (pas de spam, promis) !</p>
        <form class="email-form" action="https://formspree.io/f/placeholder" method="POST">
          <input type="hidden" name="theme" value="reve" />
          <div class="form-row">
            <input type="email" name="email" placeholder="Je veux être informé des prochaines dates" required class="email-input" />
            <button type="submit" class="btn-cta">M'inscrire</button>
          </div>
          <p class="form-note">Pas de spam. Promis.</p>
        </form>
      </div>
      <div class="content-right fade-in">
        <video class="teaser-video" controls playsinline preload="metadata">
          <source src="/teaser-reve.mp4" type="video/mp4" />
        </video>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 8rem 1.5rem 4rem;
    overflow: hidden;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 40%, rgba(232, 168, 73, 0.12) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 20%, rgba(214, 90, 122, 0.08) 0%, transparent 50%),
                linear-gradient(to bottom, rgba(10, 10, 15, 0.4) 0%, rgba(10, 10, 15, 0.9) 100%);
    pointer-events: none;
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 680px;
  }

  .hero-title {
    margin-bottom: 1.5rem;
  }

  .hero-main {
    display: block;
    font-family: var(--font-heading);
    font-size: 4.5rem;
    font-weight: 700;
    line-height: 1;
    color: var(--text-primary);
    letter-spacing: 0.02em;
  }

  .hero-sub {
    display: block;
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 400;
    line-height: 1.2;
    color: var(--text-secondary);
    letter-spacing: 0.05em;
    margin-top: 0.5rem;
  }

  .hero-tagline {
    font-size: 1.15rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    line-height: 1.6;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-form {
    margin-bottom: 0;
  }

  .hero-form-row {
    display: flex;
    gap: 0.75rem;
    max-width: 480px;
    margin: 0 auto;
  }

  .hero-email {
    flex: 1;
    padding: 1rem 1.25rem;
    background: rgba(26, 26, 46, 0.8);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 1rem;
    outline: none;
    transition: border-color 0.3s ease;
  }

  .hero-email::placeholder {
    color: var(--text-secondary);
  }

  .hero-email:focus {
    border-color: var(--accent-warm);
  }

  .form-note {
    color: var(--text-secondary);
    font-size: 0.75rem;
    margin-top: 0.75rem;
    opacity: 0.7;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .content-left h2 {
    font-size: 1.75rem;
    margin-bottom: 0.75rem;
  }

  .content-left h2 + h2 {
    margin-top: 2.5rem;
  }

  .dates-place {
    color: var(--text-secondary);
    font-size: 1.05rem;
    margin-bottom: 1.5rem;
  }

  .booking-desc {
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    line-height: 1.6;
    font-size: 1rem;
  }

  .email-form {
    margin-bottom: 1rem;
  }

  .form-row {
    display: flex;
    gap: 0.75rem;
    align-items: stretch;
  }

  .email-input {
    flex: 1;
    padding: 0.85rem 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 1rem;
    outline: none;
    transition: border-color 0.3s ease;
  }

  .email-input::placeholder {
    color: var(--text-secondary);
  }

  .email-input:focus {
    border-color: var(--accent-warm);
  }

  .teaser-video {
    width: 100%;
    max-width: 400px;
    display: block;
    border-radius: 12px;
    border: 1px solid var(--border-color);
    margin: 0 auto;
  }

  @media (max-width: 900px) {
    .content-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .teaser-video {
      max-width: 100%;
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: 7rem 1rem 3rem;
    }

    .hero-main {
      font-size: 3rem;
    }

    .hero-sub {
      font-size: 1.5rem;
    }

    .hero-tagline {
      font-size: 1rem;
    }

    .hero-form-row {
      flex-direction: column;
    }

    .form-row {
      flex-direction: column;
    }
  }
</style>
