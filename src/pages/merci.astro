---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Merci — Spectacle sous hypnose | Mathieu Kuntz"
  description="Merci pour votre intérêt pour le Spectacle sous hypnose."
>
  <section class="thanks">
    <div class="container thanks-inner">
      <h1>Merci</h1>
      <p>Merci pour votre intérêt, nous vous tiendrons informé très prochainement par email des prochaines dates de représentation du Spectacle sous hypnose.</p>
    </div>
  </section>
</Layout>

<style>
  .thanks {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 8rem 1.5rem;
    background: radial-gradient(ellipse at 50% 40%, rgba(201, 168, 76, 0.12) 0%, transparent 60%), var(--bg-primary);
  }

  .thanks-inner {
    max-width: 720px;
  }

  h1 {
    font-size: 4rem;
    margin-bottom: 1.5rem;
  }

  p {
    color: var(--text-secondary);
    font-size: 1.2rem;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 3rem;
    }
  }
</style>
