---
export interface Props {
  title?: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="problem section">
  <div class="container">
    {title && <h2 class="fade-in">{title}</h2>}
    {subtitle && <p class="problem-subtitle fade-in">{subtitle}</p>}
    <div class="problem-items">
      <div class="problem-item fade-in">
        <span class="problem-icon">&rarr;</span>
        <p>Quand est la dernière fois que vous avez vécu quelque chose de vraiment nouveau ?</p>
      </div>
      <div class="problem-item fade-in">
        <span class="problem-icon">&rarr;</span>
        <p>Et si le spectacle pouvait changer la façon dont vous vous voyez ?</p>
      </div>
      <div class="problem-item fade-in">
        <span class="problem-icon">&rarr;</span>
        <p>Pas juste divertir. <em>Transformer.</em></p>
      </div>
    </div>
  </div>
</section>

<style>
  .problem {
    background: var(--bg-secondary);
  }

  .problem h2 {
    text-align: center;
    font-size: 2rem;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .problem-subtitle {
    text-align: center;
    color: var(--text-secondary);
    font-size: 1.125rem;
    margin-bottom: 3rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .problem-items {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .problem-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    transition: border-color 0.3s ease;
  }

  .problem-item:hover {
    border-color: var(--accent-gold);
  }

  .problem-icon {
    color: var(--accent-gold);
    font-size: 1.25rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .problem-item p {
    color: var(--text-primary);
    line-height: 1.6;
  }

  .problem-item em {
    color: var(--accent-gold);
    font-style: normal;
    font-weight: 600;
  }
</style>