---
export interface Props {
  photos: Array<{ src: string; alt: string }>;
}

const { photos } = Astro.props;
---

<section class="photos section">
  <div class="container">
    <h2 class="fade-in">Sur scène</h2>
    <div class="photos-grid fade-in">
      {photos.map((photo) => (
        <div class="photo-card">
          {photo.src ? (
            <img src={photo.src} alt={photo.alt} loading="lazy" />
          ) : (
            <div class="photo-placeholder">
              <span>{photo.alt}</span>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .photos h2 {
    text-align: center;
    font-size: 2rem;
    margin-bottom: 2.5rem;
  }

  .photos-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .photo-card {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border-color);
    transition: border-color 0.3s ease;
  }

  .photo-card:hover {
    border-color: var(--accent-gold);
  }

  .photo-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .photo-placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: var(--bg-card);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    font-size: 0.9rem;
    text-align: center;
    padding: 1rem;
  }

  @media (max-width: 768px) {
    .photos-grid {
      grid-template-columns: 1fr;
    }
  }
</style>