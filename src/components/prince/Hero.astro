---
---

<header class="relative w-full min-h-[90vh] flex flex-col justify-center items-center text-center px-6 py-20 overflow-hidden">
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center text-center lg:text-left z-10 w-full relative">
    <div class="lg:col-span-7 space-y-8 flex flex-col items-center lg:items-start text-center lg:text-left">
      <span class="inline-flex items-center gap-2 py-2 px-4 border border-[#E8C76A]/20 rounded-full text-base font-semibold uppercase tracking-widest text-[#E8C76A] bg-[#E8C76A]/5 backdrop-blur-sm">
        <iconify-icon icon="solar:stars-line-duotone" stroke-width="1.5" class="text-base"></iconify-icon>
        Spectacle immersif sous hypnose — 11 juillet 2026, Vif
      </span>
      <h1 class="text-4xl md:text-6xl lg:text-7xl text-[#F2EFEA] font-serif leading-[1.15] tracking-tight">
        Fermez les yeux.
        <br />
        <span class="italic font-light text-[#E8C76A]">
          Vous êtes parti.
        </span>
      </h1>
      <p class="max-w-2xl text-xl md:text-2xl text-[#F2EFEA]/90 font-light leading-relaxed">
        Le Petit Prince revient sur Terre. Et cette fois, c'est vous qui
        faites le voyage. Porté par la musique, le théâtre et l'hypnose,
        vous traversez son histoire de l'intérieur — pas en l'écoutant, en
        la vivant.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4 pt-4 w-full sm:w-auto">
        <a href="/prince#reservation" class="w-full sm:w-auto px-8 py-4 bg-[#E8C76A] text-[#0A0A14] font-semibold text-base tracking-widest uppercase rounded-full hover:bg-white hover:scale-105 transition-all duration-300 flex items-center justify-center gap-2 shadow-lg shadow-[#E8C76A]/10">
          Réserver ma place
          <iconify-icon icon="solar:arrow-right-linear" stroke-width="1.5" class="text-sm"></iconify-icon>
        </a>
        <a href="https://mathieukuntz.com/prince#artiste" class="w-full sm:w-auto px-8 py-4 border border-white/10 text-[#F2EFEA] hover:bg-white/5 hover:border-white/30 rounded-full text-base font-semibold tracking-widest uppercase transition-all duration-300 flex items-center justify-center">
          En savoir plus sur l'artiste
        </a>
      </div>
      <div class="pt-8 grid grid-cols-2 md:grid-cols-4 gap-6 w-full border-t border-white/10 text-left">
        <div class="space-y-1">
          <p class="text-sm md:text-base uppercase tracking-widest text-white/50">
            Quand
          </p>
          <p class="text-base md:text-lg font-semibold text-[#F2EFEA]">
            Samedi 11 juillet 2026 — 20h30
          </p>
        </div>
        <div class="space-y-1">
          <p class="text-sm md:text-base uppercase tracking-widest text-white/50">
            Où
          </p>
          <p class="text-base md:text-lg font-semibold text-[#F2EFEA]">
            Vif (Isère) - Salle Louis Maisonnat
          </p>
        </div>
        <div class="space-y-1">
          <p class="text-sm md:text-base uppercase tracking-widest text-white/50">
            Durée
          </p>
          <p class="text-base md:text-lg font-semibold text-[#F2EFEA]">
            Environ 1h30
          </p>
        </div>
        <div class="space-y-1">
          <p class="text-sm md:text-base uppercase tracking-widest text-white/50">
            Tarif
          </p>
          <p class="text-base md:text-lg font-semibold text-[#E8C76A]">
            Dès 14€ en ligne
          </p>
        </div>
      </div>
    </div>
    <div class="lg:col-span-5 w-full max-w-lg mx-auto lg:mx-0 h-full min-h-[450px] flex">
      <div class="relative w-full rounded-2xl overflow-hidden bg-black/40 border border-white/10 flex flex-col justify-between group hover:border-[#E8C76A]/40 transition-all duration-300 min-h-[450px]">
        <video id="prince-hero-video" class="absolute inset-0 w-full h-full rounded-2xl object-cover hidden" controls playsinline preload="metadata" poster="/teaser-prince-cover.png">
          <source src="/teaser-prince-vertical.mp4" type="video/mp4" />
        </video>
        <button id="prince-hero-video-button" type="button" class="absolute inset-0 p-6 flex flex-col justify-between text-left cursor-pointer" aria-label="Lire le teaser vidéo Prince">
          <img src="/teaser-prince-cover.png" alt="Teaser vidéo Prince" class="absolute inset-0 w-full h-full object-cover opacity-80 transition-opacity group-hover:opacity-90" loading="eager" />
          <span class="z-10 self-start px-3 py-1.5 bg-black/70 border border-white/10 rounded-md text-xs font-semibold uppercase tracking-wider text-[#E8C76A] flex items-center gap-1.5">
            <iconify-icon icon="solar:videocamera-record-bold" class="text-red-500 animate-pulse"></iconify-icon>
            Teaser Vidéo
          </span>
          <span class="absolute inset-0 flex items-center justify-center z-10">
            <span class="w-16 h-16 rounded-full bg-[#E8C76A] text-[#0A0A14] flex items-center justify-center shadow-lg shadow-[#E8C76A]/20 group-hover:scale-110 transition-transform duration-300">
              <iconify-icon icon="solar:play-bold" class="text-2xl ml-1"></iconify-icon>
            </span>
          </span>
        </button>
      </div>
    </div>
  </div>

  <!-- Abstract poetic visual -->
  <div class="absolute inset-0 -z-20 flex items-center justify-center opacity-25">
    <div class="relative w-[300px] h-[300px] md:w-[500px] md:h-[500px]">
      <div class="absolute inset-0 rounded-full border border-dashed border-[#E8C76A]/30 animate-[spin_120s_linear_infinite]"></div>
      <div class="absolute inset-8 rounded-full border border-double border-[#2A1E5C]/50 animate-[spin_80s_linear_infinite_reverse]"></div>
      <div class="absolute inset-24 rounded-full border border-white/5"></div>
      <div class="absolute top-12 left-1/2 w-1.5 h-1.5 bg-[#E8C76A] rounded-full shadow-[0_0_8px_#E8C76A]"></div>
    </div>
  </div>
</header>

<script>
  const princeHeroVideo = document.getElementById('prince-hero-video');
  const princeHeroVideoButton = document.getElementById('prince-hero-video-button');

  if (princeHeroVideo instanceof HTMLVideoElement && princeHeroVideoButton instanceof HTMLButtonElement) {
    princeHeroVideoButton.addEventListener('click', () => {
      princeHeroVideoButton.classList.add('hidden');
      princeHeroVideo.classList.remove('hidden');
      princeHeroVideo.play().catch(() => {});
    });
  }
</script>
