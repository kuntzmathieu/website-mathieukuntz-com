---
---

<footer class="bg-[#05050C] text-[#F2EFEA]/70 pt-20 pb-10 px-6 md:px-12 border-t border-white/5">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12 border-b border-white/5 pb-16">
    <!-- Col 1: Logo and brand statement -->
    <div class="space-y-4">
      <a href="/prince" class="text-2xl md:text-3xl font-serif tracking-widest text-[#E8C76A] uppercase">
        PRINCE
      </a>
      <div class="text-sm font-light space-y-1">
        <p>Spectacle immersif sous hypnose</p>
        <p class="text-[#E8C76A]">Par Mathieu Kuntz</p>
        <p class="text-white/30 pt-4">
          © 2026 Mathieu Kuntz. Tous droits réservés.
        </p>
      </div>
    </div>

    <!-- Col 2: Navigation links -->
    <div class="space-y-4">
      <h5 class="font-serif text-xl text-[#F2EFEA] tracking-tight">
        Navigation
      </h5>
      <ul class="space-y-2 text-sm font-light">
        <li>
          <a href="#experience" class="hover:text-[#E8C76A] transition-colors">
            L'expérience
          </a>
        </li>
        <li>
          <a href="#artiste" class="hover:text-[#E8C76A] transition-colors">
            L'artiste
          </a>
        </li>
        <li>
          <a href="#infos" class="hover:text-[#E8C76A] transition-colors">
            Infos pratiques
          </a>
        </li>
        <li>
          <a href="#faq" class="hover:text-[#E8C76A] transition-colors">
            Questions fréquentes
          </a>
        </li>
      </ul>
    </div>

    <!-- Col 3: Contact details -->
    <div class="space-y-4">
      <h5 class="font-serif text-xl text-[#F2EFEA] tracking-tight">
        Contact
      </h5>
      <ul class="space-y-2 text-sm font-light">
        <li class="flex items-center gap-2">
          <iconify-icon icon="solar:phone-linear" class="text-[#E8C76A]"></iconify-icon>
          <span>Réservation : 06 44 09 25 60</span>
        </li>
        <li class="flex items-center gap-2">
          <iconify-icon icon="solar:camera-linear" class="text-[#E8C76A]"></iconify-icon>
          <a href="https://instagram.com/kuntz.mathieu" target="_blank" class="hover:text-white transition-colors">
            @kuntz.mathieu
          </a>
        </li>
        <li class="flex items-center gap-2">
          <iconify-icon icon="solar:letter-linear" class="text-[#E8C76A]"></iconify-icon>
          <a href="mailto:mk@mathieukuntz.org" class="hover:text-white transition-colors">
            mk@mathieukuntz.org
          </a>
        </li>
      </ul>
    </div>

    <!-- Col 4: Booking Action -->
    <div class="space-y-4">
      <h5 class="font-serif text-xl text-[#F2EFEA] tracking-tight">
        Site Principal
      </h5>
      <p class="text-sm font-light text-[#F2EFEA]/70 leading-relaxed">
        Découvrez mes autres activités, spectacles et accompagnements.
      </p>
      <a href="/" class="inline-flex items-center gap-2 px-4 py-2 bg-white/5 hover:bg-white/10 border border-white/10 hover:border-[#E8C76A]/40 rounded-full text-sm font-semibold tracking-wider uppercase text-[#E8C76A] transition-all duration-300">
        mathieukuntz.com
        <iconify-icon icon="solar:arrow-right-linear" class="text-sm"></iconify-icon>
      </a>
    </div>
  </div>

  <div class="max-w-7xl mx-auto pt-10 flex flex-col md:flex-row justify-between items-center text-xs text-white/30 uppercase tracking-widest gap-4">
    <div class="flex gap-6">
      <a href="#" class="hover:text-[#E8C76A] transition-colors">
        Mentions légales
      </a>
      <a href="#" class="hover:text-[#E8C76A] transition-colors">
        Conditions générales de vente
      </a>
      <a href="#" class="hover:text-[#E8C76A] transition-colors">
        Politique de confidentialité
      </a>
    </div>
    <p>CONCEPTION MATHIEU KUNTZ</p>
  </div>
</footer>
