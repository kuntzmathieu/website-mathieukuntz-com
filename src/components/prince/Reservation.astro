---
---

<section id="reservation" class="py-24 px-6 md:px-12 bg-[#0C0C18] border-t border-white/5 relative overflow-hidden">
  <img src="/galactic-prince.jpg" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover opacity-[0.10] pointer-events-none -z-10" loading="lazy" />
  <div class="absolute inset-0 glow-gold opacity-50 -z-10"></div>
  <div class="max-w-4xl mx-auto z-10">
    <div class="text-center space-y-4 mb-12">
      <span class="text-base uppercase tracking-widest text-[#E8C76A] font-bold">
        Réservation
      </span>
      <h2 class="text-3xl md:text-5xl font-serif tracking-tight text-[#F2EFEA]">
        Réservez votre place.
      </h2>
      <p class="text-base md:text-lg text-[#F2EFEA]/85 font-light leading-relaxed max-w-2xl mx-auto">
        Sélectionnez vos places, payez en ligne sécurisé. Vous remplirez les
        informations de chaque participant après le paiement.
      </p>
    </div>

    <div class="rounded-2xl bg-white/[0.04] border border-[#E8C76A]/30 p-8 md:p-12 space-y-8 shadow-2xl shadow-[#E8C76A]/5">
      <!-- Selecteur quantite -->
      <div class="space-y-6">
        <div class="flex flex-col md:flex-row items-stretch md:items-center justify-between gap-4 p-6 rounded-xl bg-white/[0.05] border border-white/10">
            <div>
              <h3 class="text-lg md:text-xl font-semibold text-[#F2EFEA]">Plein tarif</h3>
              <p class="text-sm md:text-base text-white/50 font-light">19€ en ligne</p>
            </div>
            <div class="flex items-center gap-4">
              <button type="button" data-qty-btn="plein" data-action="dec" class="w-10 h-10 rounded-full border border-white/10 text-[#E8C76A] hover:bg-white/5 transition-colors text-xl flex items-center justify-center">-</button>
              <span data-qty-display="plein" class="text-2xl font-serif text-[#F2EFEA] w-8 text-center">0</span>
              <button type="button" data-qty-btn="plein" data-action="inc" class="w-10 h-10 rounded-full border border-white/10 text-[#E8C76A] hover:bg-white/5 transition-colors text-xl flex items-center justify-center">+</button>
            </div>
          </div>

          <div class="flex flex-col md:flex-row items-stretch md:items-center justify-between gap-4 p-6 rounded-xl bg-white/[0.05] border border-white/10">
            <div>
              <h3 class="text-lg md:text-xl font-semibold text-[#F2EFEA]">Tarif réduit</h3>
              <p class="text-sm md:text-base text-white/50 font-light">14€ en ligne · -25 ans, faibles revenus, familles nombreuses</p>
            </div>
          <div class="flex items-center gap-4">
            <button type="button" data-qty-btn="reduit" data-action="dec" class="w-10 h-10 rounded-full border border-white/10 text-[#E8C76A] hover:bg-white/5 transition-colors text-xl flex items-center justify-center">-</button>
            <span data-qty-display="reduit" class="text-2xl font-serif text-[#F2EFEA] w-8 text-center">0</span>
            <button type="button" data-qty-btn="reduit" data-action="inc" class="w-10 h-10 rounded-full border border-white/10 text-[#E8C76A] hover:bg-white/5 transition-colors text-xl flex items-center justify-center">+</button>
          </div>
        </div>
      </div>

      <!-- Code promo -->
      <div class="flex flex-col md:flex-row gap-3">
        <input type="text" id="promo-code" placeholder="Code promo (optionnel)" class="flex-1 px-4 py-3 bg-white/[0.02] border border-white/10 rounded-lg text-[#F2EFEA] placeholder-white/30 font-light outline-none focus:border-[#E8C76A]/40 transition-colors uppercase tracking-wider" />
        <button type="button" id="promo-apply" class="px-6 py-3 border border-white/10 text-[#F2EFEA] hover:bg-white/5 hover:border-[#E8C76A]/40 rounded-lg text-sm font-semibold tracking-wider uppercase transition-all duration-300">
          Appliquer
        </button>
      </div>
      <div id="promo-message" class="hidden text-sm font-light"></div>

      <!-- Total -->
      <div class="flex items-center justify-between border-t border-white/10 pt-6">
        <div>
          <p class="text-sm md:text-base text-white/50 uppercase tracking-widest">Total</p>
          <p id="total-amount" class="text-3xl font-serif text-[#E8C76A]">0€</p>
          <p id="total-detail" class="text-xs text-white/40 font-light"></p>
        </div>
        <button type="button" id="checkout-btn" disabled class="px-10 py-5 bg-[#E8C76A] text-[#0A0A14] font-bold text-sm tracking-widest uppercase rounded-full hover:bg-white hover:scale-105 transition-all duration-300 shadow-xl shadow-[#E8C76A]/20 disabled:opacity-30 disabled:cursor-not-allowed disabled:hover:scale-100">
          Payer
        </button>
      </div>
    </div>

    <!-- Stripe Embedded Checkout (hidden until checkout) -->
    <div id="checkout-container" class="hidden mt-8 rounded-2xl overflow-hidden border border-[#E8C76A]/30 shadow-2xl shadow-[#E8C76A]/10">
      <div id="checkout" class="min-h-[600px]"></div>
    </div>

    <!-- Réservation par téléphone -->
    <div class="mt-8 text-center">
      <p class="text-base md:text-lg text-[#F2EFEA]/70 font-light">
        Ou réservez directement par téléphone au :
      </p>
      <p class="text-2xl md:text-3xl font-serif text-[#E8C76A] tracking-wider mt-2">
        06 43 67 15 11
      </p>
    </div>
  </div>
</section>

<script is:inline define:vars={{ publishableKey: import.meta.env.PUBLIC_STRIPE_PUBLISHABLE_KEY || 'pk_test_51T7FmkLjkary4KKK7qjQokl17VSCWp73GTeihOyosgvvNstpiEl6nttWRFugmIJkA9ijia3eoc2c1VZvz8EB5SMJ001tri07K5' }}>
  const PUBLISHABLE_KEY = publishableKey;
  let qty = { plein: 0, reduit: 0 };
  let promoResult = null;
  let stripe = null;

  function loadStripeScript() {
    return new Promise((resolve, reject) => {
      if (window.Stripe) return resolve(window.Stripe(PUBLISHABLE_KEY));
      const s = document.createElement('script');
      s.src = 'https://js.stripe.com/v3/';
      s.onload = () => resolve(window.Stripe(PUBLISHABLE_KEY));
      s.onerror = () => reject(new Error('Impossible de charger Stripe'));
      document.head.appendChild(s);
    });
  }

  function updateDisplay() {
    document.querySelector('[data-qty-display="plein"]').textContent = qty.plein;
    document.querySelector('[data-qty-display="reduit"]').textContent = qty.reduit;
    const total = qty.plein * 19 + qty.reduit * 14;
    let displayTotal = total;
    let detail = '';
    if (promoResult && promoResult.valide) {
      displayTotal = promoResult.montant_apres;
      detail = `Remise: -${(total - displayTotal).toFixed(2)}€ (code ${promoResult.code})`;
    }
    document.getElementById('total-amount').textContent = displayTotal.toFixed(2).replace('.', ',') + '€';
    document.getElementById('total-detail').textContent = detail;
    document.getElementById('checkout-btn').disabled = (qty.plein + qty.reduit) === 0;
  }

  document.querySelectorAll('[data-qty-btn]').forEach(btn => {
    btn.addEventListener('click', () => {
      const type = btn.dataset.qtyBtn;
      const action = btn.dataset.action;
      if (action === 'inc') qty[type]++;
      else qty[type] = Math.max(0, qty[type] - 1);
      updateDisplay();
    });
  });

  document.getElementById('promo-apply').addEventListener('click', async () => {
    const code = document.getElementById('promo-code').value.trim();
    if (!code) return;
    const msg = document.getElementById('promo-message');
    msg.classList.remove('hidden');
    msg.textContent = 'Vérification...';
    msg.className = 'text-sm text-white/50 font-light';
    try {
      const res = await fetch('/api/validate-promo', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code, plein_tarif: qty.plein, tarif_reduit: qty.reduit }),
      });
      const data = await res.json();
      if (res.ok) {
        promoResult = data;
        msg.textContent = `✓ Code valide — ${data.description || data.type_reduction}`;
        msg.className = 'text-sm text-[#E8C76A] font-light';
      } else {
        promoResult = null;
        msg.textContent = '✗ ' + (data.error || 'Code invalide');
        msg.className = 'text-sm text-red-400 font-light';
      }
      updateDisplay();
    } catch (e) {
      msg.textContent = 'Erreur de vérification';
      msg.className = 'text-sm text-red-400 font-light';
    }
  });

  document.getElementById('checkout-btn').addEventListener('click', async () => {
    const btn = document.getElementById('checkout-btn');
    btn.disabled = true;
    btn.textContent = 'Chargement...';
    try {
      const checkoutEventId = 'ic_' + crypto.randomUUID();
      const res = await fetch('/api/create-checkout-session', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          plein_tarif: qty.plein,
          tarif_reduit: qty.reduit,
          code_promo: document.getElementById('promo-code').value.trim(),
          event_id: checkoutEventId,
        }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Erreur');
      if (window.fbq) {
        window.fbq('track', 'InitiateCheckout', { currency: 'EUR', value: data.montant_total || 0 }, { eventID: checkoutEventId });
      }
      const s = await loadStripeScript();
      const checkout = await s.initEmbeddedCheckout({
        clientSecret: data.clientSecret,
      });
      document.getElementById('checkout').innerHTML = '';
      checkout.mount('#checkout');
      const checkoutContainer = document.getElementById('checkout-container');
      checkoutContainer.classList.remove('hidden');
      // Centre le container Stripe verticalement dans le viewport
      function centerCheckout() {
        const rect = checkoutContainer.getBoundingClientRect();
        const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        const target = scrollTop + rect.top - (window.innerHeight - rect.height) / 2;
        window.scrollTo({ top: Math.max(0, target), behavior: 'smooth' });
      }
      // Centre tout de suite, puis re-centre quand l'iframe Stripe a fini de charger
      centerCheckout();
      setTimeout(centerCheckout, 400);
      setTimeout(centerCheckout, 1000);
    } catch (e) {
      alert(e.message);
    } finally {
      btn.disabled = false;
      btn.textContent = 'Payer';
    }
  });

  updateDisplay();
</script>
