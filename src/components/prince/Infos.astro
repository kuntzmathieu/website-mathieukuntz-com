---
---

<section id="infos" class="py-24 px-6 md:px-12 bg-[#0C0C18]/60 border-t border-white/5 relative">
  <div class="max-w-4xl mx-auto">
    <div class="text-center space-y-4 mb-16">
      <span class="text-sm uppercase tracking-widest text-[#E8C76A] font-bold">
        Infos pratiques
      </span>
      <h2 class="text-3xl md:text-5xl font-serif tracking-tight text-[#F2EFEA]">
        Tout ce qu'il faut savoir.
      </h2>
    </div>

    <!-- Custom Table / Grid structure -->
    <div class="border border-white/10 rounded-2xl overflow-hidden bg-[#0A0A14] divide-y divide-white/5">
      <div class="grid grid-cols-3 p-6 gap-4 items-center">
        <span class="text-xs md:text-sm uppercase tracking-widest text-[#E8C76A] font-bold col-span-1">
          Date &amp; Heure
        </span>
        <span class="text-sm md:text-base text-[#F2EFEA] col-span-2 font-semibold">
          Samedi 11 juillet 2026 à 20h00
        </span>
      </div>
      <div class="grid grid-cols-3 p-6 gap-4 items-center">
        <span class="text-xs md:text-sm uppercase tracking-widest text-[#E8C76A] font-bold col-span-1">
          Lieu
        </span>
        <div class="text-sm md:text-base text-[#F2EFEA] col-span-2 font-semibold space-y-1">
          <p>Salle polyvalente Louis Maisonat, Vif (Isère)</p>
          <p class="text-xs md:text-sm text-[#F2EFEA]/60 font-light">
            43 Rue du 19 Mars 1962, 38450 Vif
          </p>
          <p class="text-xs md:text-sm text-[#F2EFEA]/60 font-light">
            Parking gratuit sur place
          </p>
        </div>
      </div>
      <div class="grid grid-cols-3 p-6 gap-4 items-center">
        <span class="text-xs md:text-sm uppercase tracking-widest text-[#E8C76A] font-bold col-span-1">
          Durée
        </span>
        <span class="text-sm md:text-base text-[#F2EFEA] col-span-2 font-semibold">
          Environ 1h30
        </span>
      </div>
      <div class="grid grid-cols-3 p-6 gap-4 items-center">
        <span class="text-xs md:text-sm uppercase tracking-widest text-[#E8C76A] font-bold col-span-1">
          Tarifs
        </span>
        <div class="text-sm md:text-base text-[#F2EFEA] col-span-2 space-y-2">
          <p class="font-bold text-[#E8C76A]">
            En ligne : 19€ plein tarif / 14€ tarif réduit
          </p>
          <p class="font-normal text-[#F2EFEA]/80">
            Sur place / Par téléphone : 20€ plein tarif / 15€ tarif réduit
          </p>
          <p class="text-white/40 text-xs uppercase font-light">
            Tarif réduit : -25 ans, faibles revenus &amp; familles
            nombreuses
          </p>
        </div>
      </div>
      <div class="grid grid-cols-3 p-6 gap-4 items-center">
        <span class="text-xs md:text-sm uppercase tracking-widest text-[#E8C76A] font-bold col-span-1">
          Public
        </span>
        <div class="text-sm md:text-base text-[#F2EFEA] col-span-2 font-semibold space-y-1">
          <p>Tout public, recommandé à partir de 7-8 ans. (Voir FAQ)</p>
          <p class="text-xs md:text-sm text-[#F2EFEA]/60 font-light">
            Intérêt, calme et capacité d'attention suffisante requise
          </p>
        </div>
      </div>
      <div class="grid grid-cols-3 p-6 gap-4 items-center">
        <span class="text-xs md:text-sm uppercase tracking-widest text-[#E8C76A] font-bold col-span-1">
          Accessibilité
        </span>
        <span class="text-sm md:text-base text-[#F2EFEA] col-span-2 font-semibold">
          Accessible aux personnes à mobilité réduite / fauteuil roulant.
        </span>
      </div>
      <div class="grid grid-cols-3 p-6 gap-4 items-center">
        <span class="text-xs md:text-sm uppercase tracking-widest text-[#E8C76A] font-bold col-span-1">
          Restauration
        </span>
        <div class="text-sm md:text-base text-[#F2EFEA] col-span-2 font-semibold space-y-1">
          <p>Buvette et snack sur place, avant et après le spectacle</p>
          <p class="text-xs md:text-sm text-[#F2EFEA]/60 font-light">
            Ventes au profit de l'association XXX
          </p>
        </div>
      </div>
    </div>

    <div class="mt-12 text-center">
      <a href="/prince#reservation" class="inline-flex items-center gap-2 px-10 py-5 bg-[#E8C76A] text-[#0A0A14] font-bold text-sm tracking-widest uppercase rounded-full hover:bg-white hover:scale-105 transition-all duration-300">
        Réserver ma place en ligne
        <iconify-icon icon="solar:arrow-right-linear" stroke-width="1.5" class="text-sm"></iconify-icon>
      </a>
    </div>
  </div>
</section>
