---
---

<section id="membership" class="py-32 bg-white">
  <div class="max-w-screen-xl mx-auto px-6 md:px-12">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl tracking-tight font-medium text-[#1a1a1a] mb-4">Simple, transparent pricing</h2>
      <p class="text-lg text-[#5c5c5a]">Choose the plan that fits your practice.</p>
      <div class="mt-8 inline-flex items-center gap-3">
        <span class="text-sm font-medium text-[#1a1a1a]">Monthly</span>
        <div class="w-12 h-6 bg-[#e8eae4] rounded-full relative cursor-pointer" onclick="this.classList.toggle('bg-[#5d674f]'); this.children[0].classList.toggle('translate-x-6'); this.children[0].classList.toggle('bg-white')">
          <div class="w-5 h-5 bg-[#5d674f] rounded-full absolute top-0.5 left-0.5 transition-all duration-300"></div>
        </div>
        <span class="text-sm font-medium text-[#5c5c5a]">Annually <span class="text-xs text-[#5d674f] ml-1">(Save 20%)</span></span>
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-8 items-center">
      <div class="border border-[#dcdacd] rounded-[2rem] p-8 flex flex-col h-full hover:border-[#1a1a1a] transition-colors">
        <h3 class="text-xl font-medium text-[#1a1a1a] mb-2">Drop-in</h3>
        <div class="flex items-baseline gap-1 mb-6">
          <span class="text-4xl tracking-tight font-medium text-[#1a1a1a]">$25</span>
          <span class="text-sm text-[#5c5c5a]">/class</span>
        </div>
        <ul class="space-y-4 mb-8 flex-grow">
          <li class="flex items-start gap-3 text-base text-[#5c5c5a]">
            <i data-lucide="check" class="w-5 h-5 stroke-[1.5] text-[#1a1a1a] shrink-0"></i> Single class access
          </li>
          <li class="flex items-start gap-3 text-base text-[#5c5c5a]">
            <i data-lucide="check" class="w-5 h-5 stroke-[1.5] text-[#1a1a1a] shrink-0"></i> Mat rental included
          </li>
        </ul>
        <button class="w-full border border-[#1a1a1a] text-[#1a1a1a] py-3 rounded-full font-medium hover:bg-[#1a1a1a] hover:text-white transition-colors">Buy Pass</button>
      </div>

      <div class="bg-[#1a1a1a] text-white rounded-[2rem] p-8 flex flex-col h-full transform md:-translate-y-4 shadow-2xl relative overflow-hidden">
        <div class="absolute top-0 right-0 bg-[#5d674f] text-[10px] tracking-widest uppercase font-medium px-4 py-1 rounded-bl-xl">Most Popular</div>
        <h3 class="text-xl font-medium mb-2 text-white/90">Unlimited Monthly</h3>
        <div class="flex items-baseline gap-1 mb-6">
          <span class="text-5xl tracking-tight font-medium">$150</span>
          <span class="text-sm text-white/60">/mo</span>
        </div>
        <ul class="space-y-4 mb-8 flex-grow">
          <li class="flex items-start gap-3 text-base text-white/80">
            <i data-lucide="check" class="w-5 h-5 stroke-[1.5] text-[#e8eae4] shrink-0"></i> Unlimited classes
          </li>
          <li class="flex items-start gap-3 text-base text-white/80">
            <i data-lucide="check" class="w-5 h-5 stroke-[1.5] text-[#e8eae4] shrink-0"></i> 2 guest passes/mo
          </li>
          <li class="flex items-start gap-3 text-base text-white/80">
            <i data-lucide="check" class="w-5 h-5 stroke-[1.5] text-[#e8eae4] shrink-0"></i> 10% off retail & workshops
          </li>
          <li class="flex items-start gap-3 text-base text-white/80">
            <i data-lucide="check" class="w-5 h-5 stroke-[1.5] text-[#e8eae4] shrink-0"></i> Free premium mat storage
          </li>
        </ul>
        <button class="w-full bg-white text-[#1a1a1a] py-3 rounded-full font-medium hover:bg-[#f5f4f0] transition-colors">Subscribe Now</button>
      </div>

      <div class="border border-[#dcdacd] rounded-[2rem] p-8 flex flex-col h-full hover:border-[#1a1a1a] transition-colors">
        <h3 class="text-xl font-medium text-[#1a1a1a] mb-2">10-Class Pack</h3>
        <div class="flex items-baseline gap-1 mb-6">
          <span class="text-4xl tracking-tight font-medium text-[#1a1a1a]">$200</span>
        </div>
        <ul class="space-y-4 mb-8 flex-grow">
          <li class="flex items-start gap-3 text-base text-[#5c5c5a]">
            <i data-lucide="check" class="w-5 h-5 stroke-[1.5] text-[#1a1a1a] shrink-0"></i> Valid for 6 months
          </li>
          <li class="flex items-start gap-3 text-base text-[#5c5c5a]">
            <i data-lucide="check" class="w-5 h-5 stroke-[1.5] text-[#1a1a1a] shrink-0"></i> Shareable with friends
          </li>
          <li class="flex items-start gap-3 text-base text-[#5c5c5a]">
            <i data-lucide="check" class="w-5 h-5 stroke-[1.5] text-[#1a1a1a] shrink-0"></i> Mat rental included
          </li>
        </ul>
        <button class="w-full border border-[#1a1a1a] text-[#1a1a1a] py-3 rounded-full font-medium hover:bg-[#1a1a1a] hover:text-white transition-colors">Buy Pack</button>
      </div>
    </div>
  </div>
</section>
