---
---

<section id="activites" class="py-24 md:py-40 bg-white border-t border-[#dcdacd]">
  <div class="max-w-screen-xl mx-auto px-6 md:px-12">
    <div class="mb-16 md:mb-24 flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div>
        <span class="text-[10px] font-medium tracking-[0.2em] uppercase text-[#5d674f] mb-4 block">
          Ce que je fais
        </span>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-medium tracking-tight text-[#1a1a1a]">
          Mes activités
        </h2>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pb-12">
      <div class="bg-[#f5f4f0] rounded-[32px] p-4 flex flex-col group transition-colors hover:shadow-xl hover:shadow-black/5 duration-500">
        <div class="w-full aspect-[4/3] rounded-[24px] overflow-hidden mb-6 bg-white">
          <img src="https://images.unsplash.com/photo-1514525253161-7a46d19cd819?q=80&w=600&auto=format&fit=crop" alt="Spectacles" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
        </div>
        <div class="px-2 flex-grow flex flex-col">
          <h3 class="text-2xl font-medium tracking-tight text-[#1a1a1a] mb-3">
            Spectacles
          </h3>
          <p class="text-base text-[#5c5c5a] font-light leading-relaxed mb-6 flex-grow">
            Du théâtre, de l'hypnose, de l'humour. Des spectacles à
            message à voir autant qu'à vivre, pour passer un bon moment,
            réfléchir et en ressortir un peu différent.
          </p>
          <a href="/prince" class="inline-flex items-center gap-2 text-[10px] font-medium tracking-[0.2em] uppercase text-[#1a1a1a] group-hover:text-[#5d674f] transition-colors mt-auto">
            Voir PRINCE
            <i data-lucide="arrow-up-right" class="w-4 h-4 stroke-[1.5]"></i>
          </a>
        </div>
      </div>
      <div class="bg-[#f5f4f0] rounded-[32px] p-4 flex flex-col group transition-colors hover:shadow-xl hover:shadow-black/5 duration-500">
        <div class="w-full aspect-[4/3] rounded-[24px] overflow-hidden mb-6 bg-white">
          <img src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?q=80&w=600&auto=format&fit=crop" alt="Thérapie & accompagnement" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
        </div>
        <div class="px-2 flex-grow flex flex-col">
          <h3 class="text-2xl font-medium tracking-tight text-[#1a1a1a] mb-3">
            Thérapie & accompagnement
          </h3>
          <p class="text-base text-[#5c5c5a] font-light leading-relaxed mb-6 flex-grow">
            Hypnose & thérapie brève, préparation mentale, coaching.
            Enfants, ados, adultes.
          </p>
          <a href="/#contact" class="inline-flex items-center gap-2 text-[10px] font-medium tracking-[0.2em] uppercase text-[#1a1a1a] group-hover:text-[#5d674f] transition-colors mt-auto">
            Me contacter
            <i data-lucide="arrow-right" class="w-4 h-4 stroke-[1.5]"></i>
          </a>
        </div>
      </div>
      <div class="bg-[#f5f4f0] rounded-[32px] p-4 flex flex-col group transition-colors hover:shadow-xl hover:shadow-black/5 duration-500">
        <div class="w-full aspect-[4/3] rounded-[24px] overflow-hidden mb-6 bg-white">
          <img src="https://images.unsplash.com/photo-1551632811-561732d1e306?q=80&w=600&auto=format&fit=crop" alt="Stages & aventures" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
        </div>
        <div class="px-2 flex-grow flex flex-col">
          <h3 class="text-2xl font-medium tracking-tight text-[#1a1a1a] mb-3">
            Stages & aventures
          </h3>
          <p class="text-base text-[#5c5c5a] font-light leading-relaxed mb-6 flex-grow">
            Ski nordique, arts vivants, écologie, politique, dév perso.
            Stages immersifs, sport, voyage, exploration intérieure.
            Utiliser le corps et le dehors pour bouger le dedans.
          </p>
          <a href="/#contact" class="inline-flex items-center gap-2 text-[10px] font-medium tracking-[0.2em] uppercase text-[#1a1a1a] group-hover:text-[#5d674f] transition-colors mt-auto">
            Me contacter
            <i data-lucide="arrow-right" class="w-4 h-4 stroke-[1.5]"></i>
          </a>
        </div>
      </div>
      <div class="bg-[#f5f4f0] rounded-[32px] p-4 flex flex-col group transition-colors hover:shadow-xl hover:shadow-black/5 duration-500">
        <div class="w-full aspect-[4/3] rounded-[24px] overflow-hidden mb-6 bg-white">
          <img src="https://images.unsplash.com/photo-1544531586-fde5298cdd40?q=80&w=600&auto=format&fit=crop" alt="Interventions & formation" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
        </div>
        <div class="px-2 flex-grow flex flex-col">
          <h3 class="text-2xl font-medium tracking-tight text-[#1a1a1a] mb-3">
            Interventions & formation
          </h3>
          <p class="text-base text-[#5c5c5a] font-light leading-relaxed mb-6 flex-grow">
            Conférences, ateliers, sensibilisation, consulting. Pour les
            écoles, assos, entreprises. Hypnose, imagination, changement,
            transmission aux jeunes.
          </p>
          <a href="/#contact" class="inline-flex items-center gap-2 text-[10px] font-medium tracking-[0.2em] uppercase text-[#1a1a1a] group-hover:text-[#5d674f] transition-colors mt-auto">
            Me contacter
            <i data-lucide="arrow-right" class="w-4 h-4 stroke-[1.5]"></i>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
