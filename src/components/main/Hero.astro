---
---

<section class="relative min-h-screen pt-44 lg:pt-52 pb-0 overflow-hidden flex flex-col justify-between">
  <div class="max-w-screen-2xl mx-auto px-6 md:px-12 w-full grid lg:grid-cols-12 gap-12 lg:gap-0 relative z-10 flex-grow">
    
    <div class="lg:col-span-5 flex flex-col justify-center relative z-20 pb-24 lg:pb-32 mt-12 lg:mt-0">
      <h1 class="text-6xl md:text-7xl lg:text-[5.5rem] leading-[1.05] tracking-tighter font-medium text-[#1a1a1a] mb-8">
        Grandir<br>et embellir,<br>concrètement.
      </h1>
      
      <div class="pl-6 border-l-[1.5px] border-[#dcdacd] mb-12">
        <p class="text-lg md:text-xl text-[#5c5c5a] font-normal leading-relaxed max-w-md">
          Vous-mêmes et le reste du monde, ensemble.<br>Oui c'est cul-cul. Mais en vrai, c'est pas si évident. Alors moi, j'aide à ça.
        </p>
      </div>
      
      <div>
        <a href="/#qui-je-suis" class="inline-flex bg-[#5d674f] text-white px-8 py-5 rounded-full items-center gap-3 hover:bg-[#4a523f] transition-colors group">
          <span class="text-base font-normal tracking-wide">En savoir plus</span>
          <i data-lucide="arrow-right" class="w-5 h-5 stroke-[1.5] group-hover:translate-x-1 transition-transform"></i>
        </a>
      </div>
    </div>

    <div class="lg:col-span-7 relative min-h-[500px] lg:min-h-full w-full lg:h-[85vh]">
      <div class="absolute top-[-5%] lg:top-[-10%] right-[-10%] lg:right-[-15%] w-[120%] lg:w-[110%] aspect-square rounded-full overflow-hidden z-0">
        <img src="/hero-portrait.jpg" alt="Portrait de Mathieu Kuntz" class="w-full h-full object-cover object-[60%_30%]">
        <div class="absolute inset-0 bg-black/5 mix-blend-overlay"></div>
      </div>

      <a href="/#activites" class="absolute top-0 lg:top-[15%] left-[20%] lg:left-[10%] bg-[#f2ece5] rounded-full w-36 h-36 flex flex-col items-center justify-center p-6 text-center shadow-sm z-20 hover:shadow-md transition-shadow">
        <i data-lucide="asterisk" class="w-5 h-5 stroke-[1] mb-2 text-[#5d674f]"></i>
        <span class="text-[9px] tracking-[0.2em] font-medium uppercase text-[#1a1a1a] leading-tight">Interventions<br>Spectacles<br>Thérapie<br>Stages</span>
      </a>

      <div class="absolute top-[40%] lg:top-[50%] left-[-5%] lg:left-[-10%] bg-[#5d674f] rounded-full w-48 h-48 lg:w-56 lg:h-56 flex items-center justify-center z-20 shadow-md">
        <svg viewBox="0 0 100 100" class="absolute inset-0 w-full h-full animate-[spin_25s_linear_infinite] p-2">
          <path id="curve" d="M 50, 50 m -42, 0 a 42,42 0 1,1 84,0 a 42,42 0 1,1 -84,0" fill="transparent"></path>
          <text class="text-[7.5px] fill-white/80 font-medium tracking-[0.25em] uppercase">
            <textPath href="#curve" startOffset="0">Un multi-potentiel • au service du vôtre •</textPath>
          </text>
        </svg>
        <div class="flex flex-col items-center">
          <div class="w-12 h-1 border-b-[1.5px] border-white/80 mb-2"></div>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8 text-white">
            <path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
            <path d="M16 12a4 4 0 1 1-8 0"></path>
            <path d="M4 22h16"></path>
          </svg>
        </div>
      </div>

      <a href="/#contact" class="hidden lg:flex absolute bottom-[15%] right-[5%] bg-gradient-to-br from-[#f2ece5] to-[#f5f4f0] rounded-t-full rounded-bl-full rounded-br-sm w-40 h-40 flex-col items-center justify-center text-center p-6 shadow-sm z-20 hover:shadow-md transition-shadow">
        <span class="text-sm font-medium text-[#1a1a1a] mb-2">Un projet ?<br>Une question ?</span>
        <p class="text-xs text-[#5c5c5a] mb-3">Contactez-moi !</p>
        <i data-lucide="arrow-right" class="w-4 h-4 stroke-[1.5] text-[#1a1a1a]"></i>
      </a>
    </div>
  </div>

  <div class="relative w-full z-20 mt-auto">
    <div class="bg-[#e8eae4] w-[95%] md:w-[85%] lg:w-[65%] rounded-tr-[80px] lg:rounded-tr-[120px] pt-12 pb-10 px-6 md:px-12 pr-16 lg:pr-32">
      <div class="max-w-xl grid grid-cols-3 gap-6 lg:gap-12">
        <div class="flex flex-col">
          <div class="w-10 h-10 rounded-full border border-[#dcdacd] flex items-center justify-center mb-4 bg-white/50">
            <i data-lucide="user" class="w-5 h-5 stroke-[1.5] text-[#1a1a1a]"></i>
          </div>
          <span class="text-3xl lg:text-4xl font-medium tracking-tight text-[#1a1a1a] mb-1">10 ans</span>
          <span class="text-[10px] tracking-widest uppercase text-[#5c5c5a]">D'hypnose</span>
        </div>

        <div class="flex flex-col relative before:content-[''] before:absolute before:left-[-1.5rem] before:top-0 before:h-full before:w-[1px] before:bg-[#dcdacd]/50">
          <div class="w-10 h-10 rounded-full border border-[#dcdacd] flex items-center justify-center mb-4 bg-white/50">
            <i data-lucide="heart" class="w-5 h-5 stroke-[1.5] text-[#1a1a1a]"></i>
          </div>
          <span class="text-3xl lg:text-4xl font-medium tracking-tight text-[#1a1a1a] mb-1">500+</span>
          <span class="text-[10px] tracking-widest uppercase text-[#5c5c5a]">Personnes touchées</span>
        </div>

        <div class="flex flex-col relative before:content-[''] before:absolute before:left-[-1.5rem] before:top-0 before:h-full before:w-[1px] before:bg-[#dcdacd]/50">
          <div class="w-10 h-10 rounded-full border border-[#dcdacd] flex items-center justify-center mb-4 bg-white/50">
            <i data-lucide="flower-2" class="w-5 h-5 stroke-[1.5] text-[#1a1a1a]"></i>
          </div>
          <span class="text-3xl lg:text-4xl font-medium tracking-tight text-[#1a1a1a] mb-1">&infin;</span>
          <span class="text-[10px] tracking-widest uppercase text-[#5c5c5a]">Manières de contribuer</span>
        </div>
      </div>
    </div>
  </div>
</section>
