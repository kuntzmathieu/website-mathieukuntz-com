<section id="teachers" class="py-32 bg-[#f5f4f0]">
  <div class="max-w-screen-2xl mx-auto px-6 md:px-12">
    <div class="text-center mb-20">
      <h2 class="text-4xl md:text-5xl tracking-tight font-medium text-[#1a1a1a] mb-4">Meet your guides</h2>
      <p class="text-lg text-[#5c5c5a] max-w-xl mx-auto">Experienced, compassionate instructors dedicated to supporting your journey.</p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-12">
      <div class="flex flex-col items-center group cursor-pointer">
        <div class="w-32 h-32 md:w-40 md:h-40 rounded-full p-1 border border-transparent group-hover:border-[#5d674f] transition-colors mb-4">
          <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?q=80&w=400&auto=format&fit=crop" alt="Teacher" class="w-full h-full object-cover rounded-full filter grayscale group-hover:grayscale-0 transition-all duration-500" loading="lazy">
        </div>
        <h4 class="text-xl tracking-tight font-medium text-[#1a1a1a]">Sarah Jenkins</h4>
        <span class="text-sm text-[#5c5c5a] uppercase tracking-widest mt-1">Vinyasa • Yin</span>
      </div>
      <div class="flex flex-col items-center group cursor-pointer">
        <div class="w-32 h-32 md:w-40 md:h-40 rounded-full p-1 border border-transparent group-hover:border-[#5d674f] transition-colors mb-4">
