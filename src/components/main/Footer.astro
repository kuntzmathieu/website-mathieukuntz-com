---
---

<footer class="bg-[#f5f4f0] pt-24 pb-12 border-t border-[#dcdacd]">
  <div class="max-w-screen-2xl mx-auto px-6 md:px-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 lg:gap-24 mb-16">
      <div class="col-span-1 md:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-6">
          <div class="w-6 h-6">
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-full h-full text-[#1a1a1a]">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"></path>
            </svg>
          </div>
          <span class="text-lg font-medium tracking-widest uppercase">Mathieu Kuntz</span>
        </a>
        <p class="text-base text-[#5c5c5a] font-normal leading-relaxed">
          Grandir et embellir, concrètement. Spectacle, thérapie, stages, enseignement.
        </p>
      </div>

      <div>
        <h4 class="text-sm font-medium tracking-widest uppercase text-[#1a1a1a] mb-6">Explorer</h4>
        <ul class="space-y-4">
          <li><a href="/#activites" class="text-base text-[#5c5c5a] hover:text-[#1a1a1a] transition-colors">Ce que je fais</a></li>
          <li><a href="/#qui-je-suis" class="text-base text-[#5c5c5a] hover:text-[#1a1a1a] transition-colors">Qui je suis</a></li>
          <li><a href="/#contact" class="text-base text-[#5c5c5a] hover:text-[#1a1a1a] transition-colors">Me contacter</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-medium tracking-widest uppercase text-[#1a1a1a] mb-6">En ce moment</h4>
        <p class="text-base text-[#5c5c5a] mb-4">PRINCE — Spectacle immersif sous hypnose.</p>
        <a href="/prince" class="inline-block bg-[#1a1a1a] text-white px-6 py-3 rounded-full text-sm font-medium hover:bg-[#333] transition-colors">Infos et feedback</a>
      </div>

      <div>
        <h4 class="text-sm font-medium tracking-widest uppercase text-[#1a1a1a] mb-6">Newsletter</h4>
        <p class="text-base text-[#5c5c5a] mb-4">Soyez informés de mes prochains spectacles, stages &amp; autres projets !</p>
        <form class="relative flex items-center">
          <input type="email" placeholder="Email address" class="w-full bg-transparent border-b border-[#dcdacd] py-2 text-base text-[#1a1a1a] placeholder:text-[#a0a09e] focus:outline-none focus:border-[#1a1a1a] transition-colors pb-3">
          <button type="submit" class="absolute right-0 top-1/2 -translate-y-1/2 p-2 text-[#1a1a1a] hover:text-[#5d674f] transition-colors">
            <i data-lucide="arrow-right" class="w-5 h-5 stroke-[1.5]"></i>
          </button>
        </form>
      </div>
    </div>

    <div class="pt-8 border-t border-[#dcdacd] flex flex-col md:flex-row items-center justify-between gap-4">
      <span class="text-sm text-[#5c5c5a]">© 2026 Mathieu Kuntz. Tous droits réservés.</span>
      <div class="flex gap-6">
        <a href="#" class="text-sm text-[#5c5c5a] hover:text-[#1a1a1a] transition-colors">Mentions légales</a>
        <a href="#" class="text-sm text-[#5c5c5a] hover:text-[#1a1a1a] transition-colors">Conditions générales</a>
      </div>
    </div>
  </div>
</footer>
