---
---

<nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-[#f5f4f0]/80 backdrop-blur-md border-b border-transparent" id="navbar">
  <div class="max-w-screen-2xl mx-auto px-6 md:px-12 h-24 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 z-50">
      <div class="relative w-8 h-8">
        <svg viewBox="0 0 24 24" fill="currentColor" class="w-full h-full text-[#1a1a1a]">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"></path>
          <path d="M12 6c-3.31 0-6 2.69-6 6s2.69 6 6 6 6-2.69 6-6-2.69-6-6-6zm0 10c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4z"></path>
          <circle cx="12" cy="12" r="2"></circle>
        </svg>
      </div>
      <div class="flex flex-col">
        <span class="text-[10px] tracking-widest text-[#5c5c5a] uppercase leading-none">Mathieu</span>
        <span class="text-[10px] font-medium tracking-widest text-[#1a1a1a] uppercase mt-1">KUNTZ</span>
      </div>
    </a>

    <!-- PRINCE CTA (between logo and menu, desktop only) -->
    <a href="/prince" class="hidden lg:flex items-center gap-4 px-8 py-4 rounded-2xl overflow-hidden relative group transition-all duration-300 hover:scale-[1.03] ml-6 mr-auto shadow-lg" style="background-image: url('/teaser-prince-cover.png'); background-size: cover; background-position: center; min-height: 56px;">
      <div class="absolute inset-0 bg-black/50 group-hover:bg-black/40 transition-colors"></div>
      <span class="relative text-white font-bold text-lg tracking-wider uppercase">PRINCE</span>
      <span class="relative text-white/80 text-sm hidden xl:inline">11 juillet · Vif</span>
      <span class="relative bg-[#e8eae4] text-[#1a1a1a] px-4 py-2 rounded-full text-sm font-bold whitespace-nowrap">Réserver ma place</span>
    </a>

    <div class="hidden lg:flex items-center gap-10">
      <a href="/#activites" class="text-base text-[#1a1a1a] hover:text-[#5d674f] transition-colors font-normal">Ce que je fais</a>
      <a href="/#qui-je-suis" class="text-base text-[#1a1a1a] hover:text-[#5d674f] transition-colors font-normal">Qui je suis</a>
      <a href="/#contact" class="text-base text-[#1a1a1a] hover:text-[#5d674f] transition-colors font-normal">Contact</a>
      <a href="/#contact" class="bg-[#1a1a1a] text-white px-6 py-3 rounded-full text-base font-normal hover:bg-[#333] transition-colors">Me contacter</a>
    </div>

    <button class="lg:hidden z-50 p-2" id="mobile-menu-btn" aria-label="Toggle Menu">
      <i data-lucide="menu" class="w-6 h-6 stroke-[1.5]"></i>
    </button>
  </div>

  <div id="mobile-menu" class="fixed inset-0 bg-[#f5f4f0] z-40 flex flex-col justify-center items-center gap-8 opacity-0 pointer-events-none transition-opacity duration-300">
    <a href="/#activites" class="text-3xl font-medium tracking-tight text-[#1a1a1a] mobile-link">Ce que je fais</a>
    <a href="/#qui-je-suis" class="text-3xl font-medium tracking-tight text-[#1a1a1a] mobile-link">Qui je suis</a>
    <a href="/#contact" class="text-3xl font-medium tracking-tight text-[#1a1a1a] mobile-link">Contact</a>
  </div>
</nav>

<!-- PromoBanner PRINCE (sous la navbar, desktop + mobile, dismissible) -->
<div id="promo-banner" class="fixed top-24 left-0 right-0 z-40 transition-all duration-300" style="background-image: url('/teaser-prince-cover.png'); background-size: cover; background-position: center;">
  <div class="absolute inset-0 bg-black/50"></div>
  <a href="/prince" class="block w-full relative group">
    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors"></div>
    <div class="relative flex flex-col md:flex-row items-center justify-center gap-3 md:gap-6 px-6 md:px-12 py-6 md:py-8">
      <span class="text-white font-bold text-xl md:text-2xl tracking-wider uppercase">PRINCE</span>
      <span class="hidden md:inline text-white/30">•</span>
      <span class="text-white/90 text-sm md:text-base font-normal text-center">11 juillet 2026, Vif (Isère). Spectacle immersif sous hypnose. Places limitées.</span>
      <span class="bg-[#e8eae4] text-[#1a1a1a] px-5 py-2.5 rounded-full font-bold text-sm md:text-base hover:bg-white transition-colors tracking-wide whitespace-nowrap">
        Réserver ma place
      </span>
    </div>
  </a>
  <button id="promo-close" class="absolute top-3 right-3 md:top-4 md:right-6 text-white/60 hover:text-white transition-colors z-10" aria-label="Fermer le bandeau">
    <i data-lucide="x" class="w-6 h-6 stroke-[1.5]"></i>
  </button>
</div>
