<section class="py-24 bg-[#5d674f] text-white">
  <div class="max-w-screen-xl mx-auto px-6 md:px-12 grid md:grid-cols-3 gap-12 lg:gap-20">
    <div class="flex flex-col items-center text-center">
      <i data-lucide="sun" class="w-8 h-8 stroke-[1.5] mb-6 text-[#e8eae4]"></i>
      <h3 class="text-2xl tracking-tight font-medium mb-3">Natural Light</h3>
      <p class="text-base text-white/80 font-normal">Our studio features floor-to-ceiling windows, allowing your practice to sync with the natural rhythms of the day.</p>
    </div>
    <div class="flex flex-col items-center text-center">
      <i data-lucide="droplets" class="w-8 h-8 stroke-[1.5] mb-6 text-[#e8eae4]"></i>
