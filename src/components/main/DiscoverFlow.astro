---
---

<section id="classes" class="py-32 bg-[#f5f4f0] overflow-hidden">
  <div class="max-w-screen-2xl mx-auto px-6 md:px-12 mb-16 flex flex-col md:flex-row md:items-end justify-between gap-8">
    <div>
      <h2 class="text-4xl md:text-5xl tracking-tight font-medium text-[#1a1a1a] mb-4">Discover your flow</h2>
      <p class="text-lg text-[#5c5c5a] max-w-xl">Curated practices designed to meet you exactly where you are today.</p>
    </div>
    <div class="flex gap-4">
      <button class="w-12 h-12 rounded-full border border-[#dcdacd] flex items-center justify-center hover:bg-white transition-colors" aria-label="Previous class">
        <i data-lucide="arrow-left" class="w-5 h-5 stroke-[1.5] text-[#1a1a1a]"></i>
      </button>
      <button class="w-12 h-12 rounded-full border border-[#dcdacd] flex items-center justify-center hover:bg-white transition-colors" aria-label="Next class">
        <i data-lucide="arrow-right" class="w-5 h-5 stroke-[1.5] text-[#1a1a1a]"></i>
      </button>
    </div>
  </div>

  <div class="flex gap-6 px-6 md:px-12 overflow-x-auto no-scrollbar snap-x snap-mandatory pb-12">
    <div class="min-w-[320px] md:min-w-[400px] bg-white rounded-[2rem] p-4 snap-start group cursor-pointer hover:shadow-xl transition-shadow duration-300">
      <div class="relative w-full aspect-[4/3] rounded-[1.5rem] overflow-hidden mb-6">
        <img src="https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/917d6f93-fb36-439a-8c48-884b67b35381_1600w.jpg" alt="Vinyasa Flow" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy">
        <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-medium uppercase tracking-widest text-[#1a1a1a]">Dynamic</div>
      </div>
      <div class="px-2 pb-4">
        <h3 class="text-2xl tracking-tight font-medium text-[#1a1a1a] mb-2">Vinyasa Flow</h3>
        <p class="text-base text-[#5c5c5a] mb-6 line-clamp-2">A dynamic, fluid practice connecting breath with movement. Build strength, flexibility, and heat.</p>
        <div class="flex items-center text-[#5d674f] font-medium text-sm group-hover:gap-2 transition-all">
          Explore Class <i data-lucide="arrow-right" class="w-4 h-4 stroke-[1.5] ml-1"></i>
        </div>
      </div>
    </div>

    <div class="min-w-[320px] md:min-w-[400px] bg-white rounded-[2rem] p-4 snap-start group cursor-pointer hover:shadow-xl transition-shadow duration-300">
      <div class="relative w-full aspect-[4/3] rounded-[1.5rem] overflow-hidden mb-6">
        <img src="https://images.unsplash.com/photo-1603988363607-e1e4a66962c6?q=80&w=2070&auto=format&fit=crop" alt="Yin Yoga" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy">
        <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-medium uppercase tracking-widest text-[#1a1a1a]">Restorative</div>
      </div>
      <div class="px-2 pb-4">
        <h3 class="text-2xl tracking-tight font-medium text-[#1a1a1a] mb-2">Yin & Restore</h3>
        <p class="text-base text-[#5c5c5a] mb-6 line-clamp-2">Slow-paced style with postures held for longer periods. Targets deep connective tissues.</p>
        <div class="flex items-center text-[#5d674f] font-medium text-sm group-hover:gap-2 transition-all">
          Explore Class <i data-lucide="arrow-right" class="w-4 h-4 stroke-[1.5] ml-1"></i>
        </div>
      </div>
    </div>

    <div class="min-w-[320px] md:min-w-[400px] bg-white rounded-[2rem] p-4 snap-start group cursor-pointer hover:shadow-xl transition-shadow duration-300">
      <div class="relative w-full aspect-[4/3] rounded-[1.5rem] overflow-hidden mb-6">
        <img src="https://images.unsplash.com/photo-1506126613408-eca07ce68773?q=80&w=2099&auto=format&fit=crop" alt="Meditation" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy">
        <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-medium uppercase tracking-widest text-[#1a1a1a]">Mindful</div>
      </div>
      <div class="px-2 pb-4">
        <h3 class="text-2xl tracking-tight font-medium text-[#1a1a1a] mb-2">Meditation & Breath</h3>
        <p class="text-base text-[#5c5c5a] mb-6 line-clamp-2">Guided mindfulness techniques and pranayama to calm the nervous system and center the mind.</p>
        <div class="flex items-center text-[#5d674f] font-medium text-sm group-hover:gap-2 transition-all">
          Explore Class <i data-lucide="arrow-right" class="w-4 h-4 stroke-[1.5] ml-1"></i>
        </div>
      </div>
    </div>

    <div class="min-w-[320px] md:min-w-[400px] bg-white rounded-[2rem] p-4 snap-start group cursor-pointer hover:shadow-xl transition-shadow duration-300">
      <div class="relative w-full aspect-[4/3] rounded-[1.5rem] overflow-hidden mb-6">
        <img src="https://images.unsplash.com/photo-1593164842264-854604db2260?q=80&w=2069&auto=format&fit=crop" alt="Hatha Yoga" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy">
        <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-medium uppercase tracking-widest text-[#1a1a1a]">Foundational</div>
      </div>
      <div class="px-2 pb-4">
        <h3 class="text-2xl tracking-tight font-medium text-[#1a1a1a] mb-2">Hatha Alignment</h3>
        <p class="text-base text-[#5c5c5a] mb-6 line-clamp-2">Focus on physical alignment and breathing techniques. Perfect for beginners and seasoned yogis.</p>
        <div class="flex items-center text-[#5d674f] font-medium text-sm group-hover:gap-2 transition-all">
          Explore Class <i data-lucide="arrow-right" class="w-4 h-4 stroke-[1.5] ml-1"></i>
        </div>
      </div>
    </div>
  </div>
</section>
