---
---

<section class="py-32 bg-white border-t border-[#dcdacd]">
  <div class="max-w-screen-xl mx-auto px-6 md:px-12">
    <div class="flex flex-col md:flex-row md:items-center justify-between mb-16 gap-6">
      <h2 class="text-4xl md:text-5xl tracking-tight font-medium text-[#1a1a1a]">Upcoming Schedule</h2>
      <div class="inline-flex bg-[#f5f4f0] p-1 rounded-full">
        <button class="px-6 py-2 rounded-full bg-white text-[#1a1a1a] font-medium text-sm shadow-sm">Today</button>
        <button class="px-6 py-2 rounded-full text-[#5c5c5a] font-medium text-sm hover:text-[#1a1a1a] transition-colors">Tomorrow</button>
        <button class="px-6 py-2 rounded-full text-[#5c5c5a] font-medium text-sm hover:text-[#1a1a1a] transition-colors">Full Week</button>
      </div>
    </div>

    <div class="flex flex-col">
      <div class="group flex flex-col md:flex-row md:items-center justify-between py-6 border-b border-[#dcdacd] hover:bg-[#f5f4f0]/50 transition-colors px-4 -mx-4 rounded-xl cursor-pointer">
        <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-16 lg:w-1/2">
          <span class="text-xl font-medium text-[#1a1a1a] w-24">07:00 AM</span>
          <div>
            <h4 class="text-xl tracking-tight font-medium text-[#1a1a1a]">Sunrise Vinyasa</h4>
            <span class="text-sm text-[#5c5c5a]">60 min • All Levels</span>
          </div>
        </div>
        <div class="flex items-center justify-between mt-4 md:mt-0 lg:w-1/2">
          <div class="flex items-center gap-3">
            <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?q=80&w=150&auto=format&fit=crop" alt="Sarah" class="w-10 h-10 rounded-full object-cover grayscale" loading="lazy">
            <span class="text-base text-[#1a1a1a] font-medium">Sarah J.</span>
          </div>
          <button class="border border-[#1a1a1a] text-[#1a1a1a] px-6 py-2 rounded-full text-sm font-medium hover:bg-[#1a1a1a] hover:text-white transition-colors">Book</button>
        </div>
      </div>

      <div class="group flex flex-col md:flex-row md:items-center justify-between py-6 border-b border-[#dcdacd] hover:bg-[#f5f4f0]/50 transition-colors px-4 -mx-4 rounded-xl cursor-pointer">
        <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-16 lg:w-1/2">
          <span class="text-xl font-medium text-[#1a1a1a] w-24">09:30 AM</span>
          <div>
            <h4 class="text-xl tracking-tight font-medium text-[#1a1a1a]">Hatha Alignment</h4>
            <span class="text-sm text-[#5c5c5a]">75 min • Intermediate</span>
          </div>
        </div>
        <div class="flex items-center justify-between mt-4 md:mt-0 lg:w-1/2">
          <div class="flex items-center gap-3">
            <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=150&auto=format&fit=crop" alt="David" class="w-10 h-10 rounded-full object-cover grayscale" loading="lazy">
            <span class="text-base text-[#1a1a1a] font-medium">David L.</span>
          </div>
          <button class="border border-[#1a1a1a] text-[#1a1a1a] px-6 py-2 rounded-full text-sm font-medium hover:bg-[#1a1a1a] hover:text-white transition-colors">Book</button>
        </div>
      </div>

      <div class="group flex flex-col md:flex-row md:items-center justify-between py-6 border-b border-[#dcdacd] hover:bg-[#f5f4f0]/50 transition-colors px-4 -mx-4 rounded-xl cursor-pointer">
        <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-16 lg:w-1/2">
          <span class="text-xl font-medium text-[#1a1a1a] w-24">12:00 PM</span>
          <div>
            <h4 class="text-xl tracking-tight font-medium text-[#1a1a1a]">Express Core Flow</h4>
            <span class="text-sm text-[#5c5c5a]">45 min • All Levels</span>
          </div>
        </div>
        <div class="flex items-center justify-between mt-4 md:mt-0 lg:w-1/2">
          <div class="flex items-center gap-3">
            <img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?q=80&w=150&auto=format&fit=crop" alt="Maya" class="w-10 h-10 rounded-full object-cover grayscale" loading="lazy">
            <span class="text-base text-[#1a1a1a] font-medium">Maya T.</span>
          </div>
          <button class="border border-[#1a1a1a] text-[#1a1a1a] px-6 py-2 rounded-full text-sm font-medium hover:bg-[#1a1a1a] hover:text-white transition-colors">Book</button>
        </div>
      </div>

      <div class="group flex flex-col md:flex-row md:items-center justify-between py-6 border-b border-[#dcdacd] hover:bg-[#f5f4f0]/50 transition-colors px-4 -mx-4 rounded-xl cursor-pointer">
        <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-16 lg:w-1/2">
          <span class="text-xl font-medium text-[#1a1a1a] w-24">06:30 PM</span>
          <div>
            <h4 class="text-xl tracking-tight font-medium text-[#1a1a1a]">Yin & Restore</h4>
            <span class="text-sm text-[#5c5c5a]">75 min • Beginner Friendly</span>
          </div>
        </div>
        <div class="flex items-center justify-between mt-4 md:mt-0 lg:w-1/2">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-[#e8eae4] flex items-center justify-center text-[#5d674f] font-medium text-xs">SJ</div>
            <span class="text-base text-[#1a1a1a] font-medium">Sarah J.</span>
          </div>
          <button class="border border-[#dcdacd] text-[#a0a09e] px-6 py-2 rounded-full text-sm font-medium cursor-not-allowed">Waitlist</button>
        </div>
      </div>
    </div>

    <div class="mt-10 text-center">
      <a href="#" class="inline-flex items-center gap-2 text-base font-medium text-[#1a1a1a] hover:text-[#5d674f] transition-colors">
        View Full Timetable <i data-lucide="arrow-right" class="w-4 h-4 stroke-[1.5]"></i>
      </a>
    </div>
  </div>
</section>
