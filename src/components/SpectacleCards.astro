---
export interface Props {
  spectacles: Array<{
    slug: string;
    title: string;
    tagline: string;
    shortDesc: string;
    emoji: string;
  }>;
}

const { spectacles } = Astro.props;
---

<section class="spectacles section">
  <div class="container">
    <h2 class="fade-in">4 spectacles, 4 expériences</h2>
    <p class="spectacles-subtitle fade-in">Choisissez l'expérience qui vous appelle</p>
    <div class="spectacles-grid">
      {spectacles.map((s) => (
        <a href={`/${s.slug}`} class="spectacle-card fade-in">
          <span class="card-emoji">{s.emoji}</span>
          <h3>{s.title}</h3>
          <p class="card-tagline">{s.tagline}</p>
          <p class="card-desc">{s.shortDesc}</p>
          <span class="card-link">Découvrir &rarr;</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .spectacles h2 {
    text-align: center;
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .spectacles-subtitle {
    text-align: center;
    color: var(--text-secondary);
    margin-bottom: 3rem;
  }

  .spectacles-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .spectacle-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 2rem;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .spectacle-card:hover {
    border-color: var(--accent-gold);
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(201, 168, 76, 0.15);
  }

  .card-emoji {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .spectacle-card h3 {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .card-tagline {
    color: var(--accent-gold);
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .card-desc {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }

  .card-link {
    color: var(--accent-gold);
    font-weight: 600;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .spectacles-grid {
      grid-template-columns: 1fr;
    }
  }
</style>