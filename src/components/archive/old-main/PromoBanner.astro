<a id="promo-banner" href="/prince" class="block w-full bg-[#0F172A] border-b border-stone-800 text-[#F2EFEA] py-5 px-6 transition-all duration-300 hover:bg-[#111827] relative z-40 shadow-md">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-3 flex-wrap md:flex-nowrap justify-center md:justify-start">
      <span class="inline-flex items-center gap-1.5 uppercase tracking-wider font-bold text-[#E8C76A] text-sm md:text-base">
        <iconify-icon icon="solar:ticket-linear" class="text-base md:text-lg" stroke-width="1.5"></iconify-icon>
        PRINCE
      </span>
      <span class="hidden md:inline text-stone-400">•</span>
      <span class="text-sm md:text-base text-stone-200 font-medium">
        11 juillet 2026, Vif (Isère). Spectacle immersif sous hypnose.
        Places limitées.
      </span>
    </div>
    <span class="px-6 py-2.5 bg-[#E8C76A] text-stone-900 rounded-full font-bold text-sm hover:bg-white transition-colors tracking-wide inline-flex items-center gap-1 shrink-0 shadow-md">
      Réserver ma place
      <iconify-icon icon="solar:arrow-right-linear" class="text-sm"></iconify-icon>
    </span>
  </div>
</a>

<!-- Mobile Menu Drawer -->
<div id="mobile-menu" class="hidden fixed inset-0 z-30 bg-[#F7F5F1] pt-24 px-6 flex flex-col space-y-6 text-lg font-medium tracking-wide">
  <button onclick="document.getElementById('mobile-menu').classList.add('hidden')" class="absolute top-6 right-6 text-2xl">
    <iconify-icon icon="solar:close-circle-linear" stroke-width="1.5"></iconify-icon>
  </button>
  <a href="/#qui-je-suis" onclick="document.getElementById('mobile-menu').classList.add('hidden')" class="border-b border-stone-200 py-2">
    Qui je suis
  </a>
  <a href="/#ce-que-je-fais" onclick="document.getElementById('mobile-menu').classList.add('hidden')" class="border-b border-stone-200 py-2">
    Ce que je fais
  </a>

  <a href="/#spectacles" onclick="document.getElementById('mobile-menu').classList.add('hidden')" class="border-b border-stone-200 py-2">
    Spectacles
  </a>
  <a href="/#accompagnement" onclick="document.getElementById('mobile-menu').classList.add('hidden')" class="border-b border-stone-200 py-2">
    Accompagnement
  </a>
  <a href="/#sur-mesure" onclick="document.getElementById('mobile-menu').classList.add('hidden')" class="border-b border-stone-200 py-2">
    Sur-mesure
  </a>
  <a href="/#contact" onclick="document.getElementById('mobile-menu').classList.add('hidden')" class="border-b border-stone-200 py-2">
    Contact
  </a>
  <a href="/#contact" onclick="document.getElementById('mobile-menu').classList.add('hidden')" class="w-full text-center py-4 bg-stone-900 text-[#F7F5F1] rounded-full mt-4">
    Me contacter
  </a>
</div>
