---
export interface Props {
  content: string; // HTML content
}

const { content } = Astro.props;
---

<section class="description section">
  <div class="container">
    <div class="description-inner fade-in">
      <div class="description-content" set:html={content} />
    </div>
  </div>
</section>

<style>
  .description-inner {
    max-width: 750px;
    margin: 0 auto;
  }

  .description-content {
    color: var(--text-primary);
    line-height: 1.8;
    font-size: 1.1rem;
  }

  .description-content :global(p) {
    margin-bottom: 1.25rem;
  }

  .description-content :global(p:last-child) {
    margin-bottom: 0;
  }

  .description-content :global(em) {
    color: var(--accent-gold);
    font-style: normal;
    font-weight: 600;
  }

  .description-content :global(strong) {
    color: var(--accent-gold);
    font-weight: 700;
  }

  .description-content :global(blockquote) {
    border-left: 3px solid var(--accent-gold);
    padding-left: 1.5rem;
    margin: 2rem 0;
    color: var(--text-secondary);
    font-style: italic;
    font-size: 1.15rem;
  }
</style>