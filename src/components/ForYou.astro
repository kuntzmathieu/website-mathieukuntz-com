---
export interface Props {
  items: Array<string>;
  title?: string;
}

const { items, title = "Ce spectacle est pour vous si..." } = Astro.props;
---

<section class="for-you section">
  <div class="container">
    <h2 class="fade-in">{title}</h2>
    <div class="for-you-list">
      {items.map((item) => (
        <div class="for-you-item fade-in">
          <span class="for-you-icon">&#10003;</span>
          <p>{item}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .for-you {
    background: var(--bg-secondary);
  }

  .for-you h2 {
    text-align: center;
    font-size: 2rem;
    margin-bottom: 2.5rem;
  }

  .for-you-list {
    max-width: 650px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .for-you-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    transition: border-color 0.3s ease;
  }

  .for-you-item:hover {
    border-color: var(--accent-gold);
  }

  .for-you-icon {
    color: var(--accent-gold);
    font-size: 1.2rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .for-you-item p {
    color: var(--text-primary);
    line-height: 1.6;
    font-size: 1.05rem;
  }
</style>