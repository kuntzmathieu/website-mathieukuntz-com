---
export interface Props {
  title: string;
  content: string; // HTML content for the promise
}

const { title, content } = Astro.props;
---

<section class="promise section">
  <div class="container">
    <div class="promise-inner fade-in">
      <h2>{title}</h2>
      <div class="promise-content" set:html={content} />
    </div>
  </div>
</section>

<style>
  .promise-inner {
    max-width: 750px;
    margin: 0 auto;
  }

  .promise h2 {
    font-size: 2rem;
    margin-bottom: 2rem;
    text-align: center;
  }

  .promise-content {
    color: var(--text-primary);
    line-height: 1.8;
    font-size: 1.1rem;
  }

  .promise-content :global(p) {
    margin-bottom: 1.25rem;
  }

  .promise-content :global(em) {
    color: var(--accent-gold);
    font-style: normal;
    font-weight: 600;
  }

  .promise-content :global(strong) {
    color: var(--accent-gold);
    font-weight: 700;
  }

  .promise-content :global(blockquote) {
    border-left: 3px solid var(--accent-gold);
    padding-left: 1.5rem;
    margin: 2rem 0;
    color: var(--text-secondary);
    font-style: italic;
  }
</style>