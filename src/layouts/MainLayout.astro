---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const {
  title,
  description,
  ogImage = 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=1000&auto=format&fit=crop',
} = Astro.props;
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <script src="https://unpkg.com/lucide@latest"></script>
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-2M6V79H761"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-2M6V79H761');
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="bg-[#f5f4f0] text-[#1a1a1a] antialiased selection:bg-[#5d674f] selection:text-white overflow-x-hidden"
    style="font-family: 'Inter', sans-serif;"
  >
    <slot />
  </body>
</html>

<style is:global>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  lucide.createIcons();

  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-link');
  let isMenuOpen = false;

  function toggleMenu() {
    isMenuOpen = !isMenuOpen;
    if (isMenuOpen) {
      mobileMenu?.classList.remove('scale-y-0', 'opacity-0', 'pointer-events-none');
      mobileMenu?.classList.add('scale-y-100', 'opacity-100', 'pointer-events-auto');
      menuBtn!.innerHTML = '<i data-lucide="x" class="w-6 h-6 stroke-[1.5]"></i>';
    } else {
      mobileMenu?.classList.add('scale-y-0', 'opacity-0', 'pointer-events-none');
      mobileMenu?.classList.remove('scale-y-100', 'opacity-100', 'pointer-events-auto');
      menuBtn!.innerHTML = '<i data-lucide="menu" class="w-6 h-6 stroke-[1.5]"></i>';
    }
    lucide.createIcons();
  }

  menuBtn?.addEventListener('click', toggleMenu);
  mobileLinks.forEach(link => link.addEventListener('click', toggleMenu));

  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar?.classList.add('shadow-sm', 'border-[#dcdacd]/50');
      navbar?.classList.remove('border-transparent');
    } else {
      navbar?.classList.remove('shadow-sm', 'border-[#dcdacd]/50');
      navbar?.classList.add('border-transparent');
    }
  });

  // Promo banner dismiss
  const promoBanner = document.getElementById('promo-banner');
  const promoClose = document.getElementById('promo-close');
  if (sessionStorage.getItem('promo-dismissed') === 'true') {
    promoBanner?.classList.add('hidden');
  }
  promoClose?.addEventListener('click', (e) => {
    e.preventDefault();
    e.stopPropagation();
    promoBanner?.classList.add('hidden');
    sessionStorage.setItem('promo-dismissed', 'true');
  });
</script>
