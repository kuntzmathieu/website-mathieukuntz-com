---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const {
  title,
  description,
  ogImage = 'https://mathieukuntz.com/teaser-prince-cover.png',
} = Astro.props;

const metaPixelId = import.meta.env.PUBLIC_META_PIXEL_ID;
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon-prince.png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    {metaPixelId && (
      <script is:inline define:vars={{ metaPixelId }}>
        !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
        n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
        document,'script','https://connect.facebook.net/fr_FR/fbevents.js');
        const pvEventId = 'pv_' + crypto.randomUUID();
        window.fbq('init', metaPixelId);
        window.fbq('track', 'PageView', {}, { eventID: pvEventId });
      </script>
    )}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
        class="antialiased selection:bg-[#E8C76A] selection:text-[#0A0A14] overflow-x-hidden relative"
        style="font-family: 'Manrope', sans-serif; background-color: #0A0A14; color: #F2EFEA;"
  >
    <!-- Ambient background light -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-7xl h-[1000px] glow-radial -z-10 pointer-events-none"></div>
    <div class="absolute top-[2500px] right-0 w-[600px] h-[600px] glow-radial -z-10 pointer-events-none opacity-60"></div>
    <div class="absolute bottom-[1000px] left-0 w-[800px] h-[800px] glow-radial -z-10 pointer-events-none opacity-50"></div>

    <slot />
  </body>
</html>

<style is:global>
  .font-serif {
    font-family: 'Cormorant Garamond', serif;
  }
  .glow-radial {
    background: radial-gradient(
      circle at center,
      rgba(42, 30, 92, 0.45) 0%,
      rgba(7, 19, 38, 0.2) 70%,
      transparent 100%
    );
  }
  .glow-gold {
    background: radial-gradient(circle at center, rgba(232, 199, 106, 0.08) 0%, transparent 70%);
  }
  details summary::-webkit-details-marker {
    display: none;
  }
</style>
