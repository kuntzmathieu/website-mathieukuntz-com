---
export interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  currentPage?: 'prince' | 'reve';
}

const { title, description, canonicalUrl, currentPage } = Astro.props;
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta name="twitter:card" content="summary_large_image" />
  <style is:global>
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --bg-primary: #0a0a0f;
      --bg-secondary: #12121a;
      --bg-card: #1a1a2e;
      --accent-gold: #c9a84c;
      --accent-gold-hover: #dbb960;
      --accent-warm: #e8a849;
      --text-primary: #f0ece2;
      --text-secondary: #a09b8c;
      --text-accent: #c9a84c;
      --border-color: #2a2a3e;
      --font-heading: 'Playfair Display', Georgia, serif;
      --font-body: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: var(--font-body);
      background-color: var(--bg-primary);
      color: var(--text-primary);
      line-height: 1.7;
      font-size: 1.125rem;
      overflow-x: hidden;
    }

    h1, h2, h3, h4 {
      font-family: var(--font-heading);
      font-weight: 700;
      line-height: 1.2;
    }

    a {
      color: var(--accent-gold);
      text-decoration: none;
      transition: color 0.3s ease;
    }
    a:hover {
      color: var(--accent-gold-hover);
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    .btn-cta {
      display: inline-block;
      background: var(--accent-gold);
      color: var(--bg-primary);
      padding: 1rem 2.5rem;
      border-radius: 4px;
      font-family: var(--font-body);
      font-weight: 700;
      font-size: 0.9rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: all 0.3s ease;
    }
    .btn-cta:hover {
      background: var(--accent-gold-hover);
      color: var(--bg-primary);
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(201, 168, 76, 0.3);
    }

    .section {
      padding: 5rem 0;
    }

    @media (max-width: 768px) {
      .section {
        padding: 3rem 0;
      }
    }

    .fade-in {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .fade-in.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="logo">Mathieu Kuntz</a>
      <nav>
        <a href="/prince" class={currentPage === 'prince' ? 'active' : ''}>Prince</a>
        <a href="/reve" class={currentPage === 'reve' ? 'active' : ''}>Rêve!</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-brand">
          <h3>Mathieu Kuntz</h3>
          <p>Spectacles d'hypnose, de magie et de sincérité — Grenoble</p>
          <div class="footer-links-inline">
            <a href="https://mathieukuntz.org" target="_blank" rel="noopener">Site principal</a>
            <a href="https://www.instagram.com/kuntz.mathieu/" target="_blank" rel="noopener">Instagram</a>
            <a href="https://www.facebook.com/mathieukuntz.hypnotiseur/" target="_blank" rel="noopener">Facebook</a>
            <a href="mailto:mk@mathieukuntz.org">Contact</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 Mathieu Kuntz. Tous droits réservés.</p>
      </div>
    </div>
  </footer>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
  </script>
</body>
</html>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(10, 10, 15, 0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-color);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem;
  }

  .logo {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--accent-gold) !important;
  }

  nav {
    display: flex;
    gap: 1.5rem;
  }

  nav a {
    font-size: 0.8rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: color 0.3s ease;
  }

  nav a:hover {
    color: var(--accent-gold);
  }

  nav a.active {
    color: var(--accent-gold);
    border-bottom: 1px solid var(--accent-gold);
  }

  .site-footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    padding: 3rem 0 1.5rem;
  }

  .footer-brand h3 {
    font-family: var(--font-heading);
    color: var(--accent-gold);
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .footer-brand p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .footer-links-inline {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-links-inline a {
    color: var(--text-secondary);
    font-size: 0.85rem;
  }

  .footer-links-inline a:hover {
    color: var(--accent-gold);
  }

  .footer-bottom {
    border-top: 1px solid var(--border-color);
    padding-top: 1.5rem;
    margin-top: 2rem;
    text-align: center;
    color: var(--text-secondary);
    font-size: 0.8rem;
  }
</style>
